{
  "name": "ngs-report-cli",
  "version": "1.1.0",
  "type": "module",
  "description": "NGS Report Generation CLI - High-quality HTML/PDF/DOCX reports from project deliverables",
  "main": "electron/main.js",
  "bin": {
    "ngs-report": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "dev": "tsc --watch",
    "dev:gui": "vite",
    "dev:interim": "vite --config interim_app/vite.config.ts",
    "gui": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js --config interim_app/vite.config.ts",
    "build:gui": "vite build",
    "build:interim": "vite build --config interim_app/vite.config.ts",
    "start:interim": "node interim_server.js",
    "generate": "node dist/cli.js generate",
    "validate": "node dist/cli.js validate",
    "watch": "node dist/cli.js watch",
    "batch": "node dist/cli.js batch",
    "test:cli": "npm run build && node --test dist/columnUtils.test.js dist/gtfParser.test.js dist/dataParser.test.js",
    "electron:dev": "electron electron/main.js --dev",
    "electron:start": "npm run build && npm run build:interim && electron electron/main.js",
    "electron:package": "npm run build && npm run build:interim && electron-builder build --win"
  },
  "build": {
    "appId": "com.unipath.ngsreport",
    "productName": "NGSReportGenerator",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "interim_app/dist/**/*",
      "templates/**/*",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "docx": "^8.5.0",
    "ejs": "^3.1.9",
    "fs-extra": "^11.2.0",
    "mammoth": "^1.12.0",
    "ora": "^8.0.1",
    "puppeteer": "^22.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.18",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
