                                <th>Sample ID</th>
                                <th>Concentration (ng/µl)</th>
                                <th>Volume (µl)</th>
                                <th>Yield (ng)</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof qubit_data !== 'undefined' && qubit_data && qubit_data.length > 0) { %>
