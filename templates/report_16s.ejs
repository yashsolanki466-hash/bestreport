                                <tr>
                                    <td><%= idx + 1 %></td>
                                    <td><%= q.sample_id %></td>
                                    <td><%= q.conc %></td>
                                    <td><%= q.vol %></td>
                                    <td><%= q.yield %></td>
                                    <td>
                                        <span class="status-badge <%= q.remarks.toLowerCase().includes('pass') ? 'status-pass' : 'status-fail' %>">
                                            <%= q.remarks %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                            <tr>
                                <td colspan="6">No Qubit data available</td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Section 5 -->
        <div id="section-5" class="section">
            <h2>5. Quantity and quality check (QC) of library on Agilent Tape Station 4150</h2>
            
            <div id="section-5-1">
