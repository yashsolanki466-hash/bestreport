                        <div style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                            <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0;">
                                <span style="font-weight: 600; font-size: 12px;">Expression Heatmap - <%= fig.comparison %></span>
                            </div>
                            <div style="padding: 15px;">
                                <img src="<%= fig.heatmap_png_src %>" alt="<%= fig.comparison %> heatmap" style="max-width: 100%; height: auto;" />
                            </div>
                        </div>
                        <p class="caption">Heatmap of significantly differentially expressed genes for <%= fig.comparison %></p>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>

            <script>
                const __dgeCharts = { ma: {}, volcano: {} };

                function openComparison(evt, compId) {
                    const tabContents = document.getElementsByClassName("tab-content");
                    for (let i = 0; i < tabContents.length; i++) {
                        tabContents[i].classList.remove("active");
                    }

                    const tabButtons = document.getElementsByClassName("tab-button");
                    for (let i = 0; i < tabButtons.length; i++) {
                        tabButtons[i].classList.remove("active");
                    }

                    document.getElementById(compId).classList.add("active");
                    evt.currentTarget.classList.add("active");

                    // Trigger chart initialization for the newly visible tab
                    // Extract comparison name from tab ID (tab-Comparison1 -> Comparison1)
                    const sanitizedName = compId.replace('tab-', '');
                    initSingleDgeChart(sanitizedName);
                }

                function __getPlotData(comp) {
                    const el = document.getElementById('plotdata-' + comp);
                    if (!el) return null;
                    try {
                        return JSON.parse(el.textContent || '');
                    } catch (e) {
                        console.error('Failed to parse plot data for ' + comp, e);
                        return null;
                    }
                }

                function __makeScatterChart(canvasId, titleText, datasets, xLabel, yLabel) {
                    const canvas = document.getElementById(canvasId);
                    if (!canvas) {
                        console.warn('Canvas not found: ' + canvasId);
                        return null;
                    }
                    
                    // Hide loading indicator
                    const container = canvas.parentElement;
                    if (container) {
                        const loader = container.querySelector('.chart-loading');
                        if (loader) loader.style.display = 'none';
                    }

                    const ctx = canvas.getContext('2d');
                    if (!ctx) {
                        console.error('Could not get 2D context for ' + canvasId);
                        return null;
                    }

                    try {
                        console.log('Creating chart for ' + canvasId + ' with ' + datasets.length + ' datasets');
                        return new Chart(canvas, {
                            type: 'scatter',
                            data: {
                                datasets: datasets.map(ds => ({
                                    label: ds.label,
                                    data: ds.data,
                                    backgroundColor: ds.backgroundColor || 'rgba(156,163,175,0.45)',
                                    pointRadius: 2.5,
                                    pointHoverRadius: 5,
                                    borderWidth: 0
                                }))
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                animation: false,
                                plugins: {
                                    title: {
                                        display: true,
                                        text: titleText,
                                        font: { size: 14, weight: '600' }
                                    },
                                    legend: {
                                        position: 'bottom',
                                        labels: { 
                                            boxWidth: 10,
                                            padding: 10,
                                            font: { size: 11 } 
                                        }
                                    },
                                    tooltip: {
                                        callbacks: {
                                            label: function(context) {
                                                const x = context.parsed.x !== undefined ? context.parsed.x.toFixed(2) : 'N/A';
                                                const y = context.parsed.y !== undefined ? context.parsed.y.toFixed(2) : 'N/A';
                                                return `(${x}, ${y})`;
                                            }
                                        }
                                    }
                                },
                                scales: {
                                    x: {
                                        title: {
                                            display: true,
                                            text: xLabel,
                                            font: { size: 12, weight: '600' }
                                        },
                                        grid: { color: '#f1f1f1' }
                                    },
                                    y: {
                                        title: {
                                            display: true,
                                            text: yLabel,
                                            font: { size: 12, weight: '600' }
                                        },
                                        grid: { color: '#f1f1f1' }
                                    }
                                }
                            }
                        });
                    } catch (e) {
                        console.error('Chart.js error for ' + canvasId, e);
                        if (container) {
                            const loader = container.querySelector('.chart-loading');
                            if (loader) {
                                loader.textContent = 'Error rendering chart';
                                loader.style.color = 'red';
                                loader.style.display = 'block';
                            }
                        }
                        return null;
                    }
                }

                function initSingleDgeChart(compId) {
                    const data = __getPlotData(compId);
                    if (!data) return;

                    // Add small delay to ensure DOM is ready and visible
                    setTimeout(() => {
                        // MA plot
                        const maCanvasId = 'ma-' + compId;
                        const maCanvas = document.getElementById(maCanvasId);
                        if (data.ma && maCanvas && !__dgeCharts.ma[compId]) {
                            const ds = [];
                            if (data.ma.ns && data.ma.ns.length) ds.push({ label: 'Not Sig', data: data.ma.ns, backgroundColor: 'rgba(156,163,175,0.35)' });
                            if (data.ma.down && data.ma.down.length) ds.push({ label: 'Down', data: data.ma.down, backgroundColor: 'rgba(59,130,246,0.6)' });
                            if (data.ma.up && data.ma.up.length) ds.push({ label: 'Up', data: data.ma.up, backgroundColor: 'rgba(239,68,68,0.6)' });
                            __dgeCharts.ma[compId] = __makeScatterChart(maCanvasId, 'MA Plot', ds, 'logCPM', 'log2FC');
                        }

                        // Volcano plot
                        const volCanvasId = 'volcano-' + compId;
                        const volCanvas = document.getElementById(volCanvasId);
                        if (data.volcano && volCanvas && !__dgeCharts.volcano[compId]) {
                            const ds = [];
                            if (data.volcano.ns && data.volcano.ns.length) ds.push({ label: 'Not Sig', data: data.volcano.ns, backgroundColor: 'rgba(156,163,175,0.35)' });
                            if (data.volcano.down && data.volcano.down.length) ds.push({ label: 'Down', data: data.volcano.down, backgroundColor: 'rgba(59,130,246,0.6)' });
                            if (data.volcano.up && data.volcano.up.length) ds.push({ label: 'Up', data: data.volcano.up, backgroundColor: 'rgba(239,68,68,0.6)' });
                            __dgeCharts.volcano[compId] = __makeScatterChart(volCanvasId, 'Volcano Plot', ds, 'log2FC', '-log10(p)');
                        }
                    }, 50);
                }

                function initDgeCharts() {
                    if (typeof Chart === 'undefined') {
                        console.error('Chart.js not loaded!');
                        document.querySelectorAll('.chart-loading').forEach(el => {
                            el.textContent = 'Chart.js library failed to load';
                            el.style.color = 'red';
                        });
                        return;
                    }

                    <% if (typeof dge_figures !== 'undefined' && dge_figures) { %>
                    <% dge_figures.forEach(function(fig, index) { %>
                    (function() {
                        const compId = <%- JSON.stringify(fig.comparison.replace(/[^a-zA-Z0-9]/g, '_')) %>;
                        // Only initialize the first one immediately, others on tab switch
                        if (<%= index %> === 0) {
                            initSingleDgeChart(compId);
                        }
                    })();
                    <% }); %>
                    <% } %>
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initDgeCharts);
                } else {
                    initDgeCharts();
                }

                // Also call on window load to be absolutely sure
                window.addEventListener('load', initDgeCharts);
            </script>
            <% } %>
        </div>

        <!-- Section 11 -->
        <div id="section-11" class="section">
            <h2>11 Functional Annotation</h2>
            <p><%= static_snippets.go?.intro || 'The Gene Ontology project provides controlled vocabularies of defined terms representing gene product properties.' %></p>

            <div class="table-wrapper">
                <div class="table-title">Table 11.1: GO Domain Distribution</div>
                <table>
                    <thead>
                        <tr>
                            <th>Ontology</th>
                            <th>Term</th>
                            <th>Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% go_distribution.forEach(function(g) { %>
                        <tr>
                            <td><%= g.ontology %></td>
                            <td><%= g.term %></td>
                            <td><%= g.count %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <p><%= static_snippets.go?.deliverables_note || '' %></p>

            <h3>11.1 Pathway Analysis</h3>
            <p><%= static_snippets.pathway?.intro || 'Ortholog assignment and mapping of Significant differentially expressed transcripts to the biological pathways were performed using KEGG automatic annotation server (KAAS).' %></p>

            <% if (func_assets && func_assets.kegg_results_preview && func_assets.kegg_results_preview.length > 0) { %>
            <div class="table-wrapper">
                <div class="table-title">Table 11.2: KEGG Pathway Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <% if (func_assets.kegg_results_preview[0]) { %>
                                <% func_assets.kegg_results_preview[0].forEach(function(col) { %>
                                <th><%= col %></th>
                                <% }); %>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% func_assets.kegg_results_preview.slice(1).forEach(function(row) { %>
                        <tr>
                            <% row.forEach(function(cell) { %>
                            <td><%= cell %></td>
                            <% }); %>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>

            <% if (func_assets && func_assets.kegg_pathway_image_src) { %>
            <div class="figure">
                <img src="<%= func_assets.kegg_pathway_image_src %>" alt="KEGG pathway" />
                <p class="caption">Representative KEGG pathway image</p>
            </div>
            <% } %>

            <% if (pathway_ex_figure_src && (!func_assets || !func_assets.kegg_pathway_image_src)) { %>
            <div class="figure">
                <img src="<%= pathway_ex_figure_src %>" alt="KEGG pathway example" />
                <p class="caption">Representative pathway example</p>
            </div>
            <% } %>

            <h3>11.2 Enrichment Analysis</h3>
            <p><%= static_snippets.enrichment?.intro || 'Over-representation (enrichment) analysis is a statistical approach used to identify biological functions, pathways, or processes that are significantly over-represented.' %></p>

            <% if (func_assets && (func_assets.barplot_image_src || func_assets.dotplot_image_src || func_assets.enrichment_image_src)) { %>
            <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin: 20px 0;">
                <% if (func_assets.barplot_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.barplot_image_src %>" alt="Enrichment Barplot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Representative Enrichment Barplot</p>
                </div>
                <% } %>
                <% if (func_assets.dotplot_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.dotplot_image_src %>" alt="Enrichment Dotplot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Representative Enrichment Dotplot</p>
                </div>
                <% } %>
                <% if (!func_assets.barplot_image_src && !func_assets.dotplot_image_src && func_assets.enrichment_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.enrichment_image_src %>" alt="Enrichment Plot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Representative Enrichment Plot</p>
                </div>
                <% } %>
            </div>
            <% } %>
        </div>

        <!-- Section 12 Deliverables -->
        <div id="section-12" class="section">
            <h2>12 Deliverables</h2>
            <p>The following deliverables were generated as part of this analysis:</p>
            <div class="table-wrapper">
                <div class="table-title">Deliverables Tree</div>
                <pre style="background: #f5f5f5; padding: 15px; border-radius: 5px; overflow-x: auto;"><%= deliverables_tree %></pre>
            </div>
        </div>

    </div>

    <button id="mobile-toc-toggle" onclick="toggleMobileSidebar()" aria-label="Toggle Navigation">☰</button>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Toggle mobile sidebar
        function toggleMobileSidebar() {
            const toc = document.getElementById('TOC');
            const btn = document.getElementById('mobile-toc-toggle');
            if (toc.classList.contains('open')) {
                toc.classList.remove('open');
                btn.innerHTML = '☰';
            } else {
                toc.classList.add('open');
                btn.innerHTML = '✕';
            }
        }

        // Close sidebar when clicking any TOC link on mobile
        document.querySelectorAll('#TOC a').forEach(link => {
            link.addEventListener('click', (e) => {
                const toc = document.getElementById('TOC');
                const btn = document.getElementById('mobile-toc-toggle');
                if (toc.classList.contains('open')) {
                    toc.classList.remove('open');
                    btn.innerHTML = '☰';
                }
                
                // Immediately highlight clicked link
                document.querySelectorAll('#TOC a').forEach(a => a.classList.remove('active'));
                link.classList.add('active');
            });
        });

        // Scroll Spy active navigation highlight logic using getBoundingClientRect
        const sections = document.querySelectorAll('.main-container .section');
        const navLinks = document.querySelectorAll('#TOC a');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const rect = section.getBoundingClientRect();
                // Check if the section is occupying the top-half of the screen
                if (rect.top <= window.innerHeight * 0.6) {
                    current = section.getAttribute('id');
                }
            });

            if (current) {
                navLinks.forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === '#' + current) {
                        link.classList.add('active');
                    }
                });
            }
        }, { capture: true, passive: true });
        
        // Trigger once on load
        window.dispatchEvent(new Event('scroll'));

        // DGE Chart
        const dgeCtx = document.getElementById('dgeChart');
        if (dgeCtx && <%= dge_chart_labels %>.length > 0) {
            new Chart(dgeCtx, {
                type: 'bar',
                data: {
                    labels: <%= JSON.stringify(dge_chart_labels) %>,
                    datasets: [
                        {
                            label: 'Upregulated',
                            data: <%= JSON.stringify(dge_chart_up) %>,
                            backgroundColor: 'rgba(220, 38, 38, 0.7)',
                            borderColor: 'rgba(220, 38, 38, 1)',
                            borderWidth: 1
                        },
                        {
                            label: 'Downregulated',
                            data: <%= JSON.stringify(dge_chart_down) %>,
                            backgroundColor: 'rgba(49, 130, 206, 0.7)',
                            borderColor: 'rgba(49, 130, 206, 1)',
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Number of Genes'
                            }
                        }
                    }
                }
            });
        }
    </script>

</body>

</html>
