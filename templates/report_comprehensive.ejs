                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <!-- MA Plot -->
                        <div class="card" style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                            <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
