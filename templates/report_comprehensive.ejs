            <% dge_figures.forEach(function(fig, index) { %>
            <% const sanitizedComp = fig.comparison.replace(/[^a-zA-Z0-9]/g, '_'); %>
            <div id="tab-<%= sanitizedComp %>" class="tab-content <%= index === 0 ? 'active' : '' %>">
                <div class="card" style="margin-top: 10px; border: 1px solid #e2e8f0; border-radius: 6px; padding: 20px;">
                    <h4 style="color: var(--primary-color); margin-bottom: 16px; font-size: 14px;">
