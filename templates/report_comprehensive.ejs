                                                            <%= r[0] %>
                                                        </td>
                                                        <td>
                                                            <%= r[1] %>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                        <% } %>
                        </div>

                        <p>
                            <%= static_snippets.dge?.stats_note || '' %>
                        </p>
                        <div class="table-wrapper">
                            <div class="table-title">Table 5.8.5: Differential expression analysis statistics</div>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Comparison</th>
                                        <th>Total Genes</th>
                                        <th>Significantly Upregulated</th>
                                        <th>Significantly Downregulated</th>
                                        <th>Total Significant</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% diff_expr_stats.forEach(function(d) { %>
                                        <tr>
                                            <td>
                                                <%= d.comparison %>
                                            </td>
                                            <td>
                                                <%= d.total_genes %>
                                            </td>
                                            <td>
                                                <%= d.sig_up %>
                                            </td>
                                            <td>
                                                <%= d.sig_down %>
                                            </td>
                                            <td class="font-bold">
                                                <%= d.total_sig %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <p>
                            <%= static_snippets.dge?.annotation_note || '' %>
                        </p>

                        <% if (dge_figures && dge_figures.length> 0) { %>
                            <h4>5.8.1. MA Plot for differentially expressed genes</h4>
                            <p>
                                <%= static_snippets.dge?.ma_plot_text || '' %>
                            </p>

                            <h4>5.8.2. Volcano plot for differentially expressed genes</h4>
                            <p>
                                <%= static_snippets.dge?.volcano_plot_text || '' %>
                            </p>
                            <p>Interactive MA and Volcano plots are provided below for each comparison. These plots
                                visualize the distribution of differentially expressed genes and can be expanded for
                                detailed analysis. Click on the expand button (⛶) to view the plot in full screen. The
                                PDF
                                versions of these plots are also available for download.</p>

                            <div class="tab-container">
                                <% dge_figures.forEach(function(fig, index) { %>
                                    <% const sanitizedComp=fig.comparison.replace(/[^a-zA-Z0-9]/g, '_' ); %>
                                        <button class="tab-button <%= index === 0 ? 'active' : '' %>"
                                            onclick="openComparison(event, 'tab-<%= sanitizedComp %>')">
                                            <%= fig.comparison %>
                                        </button>
                                        <% }); %>
                            </div>

                            <% dge_figures.forEach(function(fig, index) { %>
                                <% const sanitizedComp=fig.comparison.replace(/[^a-zA-Z0-9]/g, '_' ); %>
                                    <div id="tab-<%= sanitizedComp %>"
                                        class="tab-content <%= index === 0 ? 'active' : '' %>">
                                        <div class="card"
                                            style="margin-top: 10px; border: 1px solid #e2e8f0; border-radius: 6px; padding: 20px;">
                                            <h4
                                                style="color: var(--primary-color); margin-bottom: 16px; font-size: 14px;">
                                                Comparison: <%= fig.comparison %>
                                            </h4>

                                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                                                <!-- MA Plot -->
                                                <div class="card"
                                                    style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                                                    <div
                                                        style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                                                        <span style="font-weight: 600; font-size: 12px;">MA Plot</span>
                                                    </div>
                                                    <div style="height: 350px; padding: 15px; position: relative;">
                                                        <div class="chart-loading"
                                                            style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #999; font-size: 12px;">
                                                            Loading chart...</div>
                                                        <% if (fig.ma_plot_data || fig.volcano_plot_data) { %>
                                                            <script type="application/json"
                                                                id="plotdata-<%= sanitizedComp %>"><%- fig.plot_data_json %></script>
                                                            <% } %>

                                                                <% if (fig.ma_plot_data) { %>
                                                                    <canvas id="ma-<%= sanitizedComp %>"
                                                                        class="ma-plot-canvas"
                                                                        style="display: block; width: 100%; height: 100%;"></canvas>
                                                                    <% } else { %>
                                                                        <div
                                                                            style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                                                            <span style="color: #666;">MA Plot data not
                                                                                available</span>
                                                                        </div>
                                                                        <% } %>
                                                    </div>
                                                </div>

                                                <!-- Volcano Plot -->
                                                <div class="card"
                                                    style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                                                    <div
                                                        style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                                                        <span style="font-weight: 600; font-size: 12px;">Volcano
                                                            Plot</span>
                                                    </div>
                                                    <div style="height: 350px; padding: 15px; position: relative;">
                                                        <div class="chart-loading"
                                                            style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #999; font-size: 12px;">
                                                            Loading chart...</div>
                                                        <% if (fig.volcano_plot_data) { %>
                                                            <canvas id="volcano-<%= sanitizedComp %>"
                                                                class="volcano-plot-canvas"
                                                                style="display: block; width: 100%; height: 100%;"></canvas>
                                                            <% } else { %>
                                                                <div
                                                                    style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                                                    <span style="color: #666;">Volcano Plot data not
                                                                        available</span>
                                                                </div>
                                                                <% } %>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Heatmap -->
                                            <% if (fig.heatmap_png_src) { %>
                                                <div class="figure" style="margin-top: 20px;">
                                                    <div
                                                        style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                                                        <div
                                                            style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0;">
                                                            <span style="font-weight: 600; font-size: 12px;">Expression
                                                                Heatmap - <%= fig.comparison %></span>
                                                        </div>
                                                        <div style="padding: 15px;">
                                                            <img src="<%= fig.heatmap_png_src %>"
                                                                alt="<%= fig.comparison %> heatmap"
                                                                style="max-width: 100%; height: auto;" />
                                                        </div>
                                                    </div>
                                                    <p class="caption">Figure 5.8.3: Heatmap for significantly
                                                        differential expressed genes for <%= fig.comparison %>
                                                    </p>
                                                </div>
                                                <% } %>
                                        </div>
                                    </div>
                                    <% }); %>

                                        <script>
                                            const __dgeCharts = { ma: {}, volcano: {} };

                                            function openComparison(evt, compId) {
                                                const tabContents = document.getElementsByClassName("tab-content");
                                                for (let i = 0; i < tabContents.length; i++) {
                                                    tabContents[i].classList.remove("active");
                                                }

                                                const tabButtons = document.getElementsByClassName("tab-button");
                                                for (let i = 0; i < tabButtons.length; i++) {
                                                    tabButtons[i].classList.remove("active");
                                                }

                                                document.getElementById(compId).classList.add("active");
                                                evt.currentTarget.classList.add("active");

                                                // Trigger chart initialization for the newly visible tab
                                                // Extract comparison name from tab ID (tab-Comparison1 -> Comparison1)
                                                const sanitizedName = compId.replace('tab-', '');
                                                initSingleDgeChart(sanitizedName);
                                            }

                                            function __getPlotData(comp) {
                                                const el = document.getElementById('plotdata-' + comp);
                                                if (!el) return null;
                                                try {
                                                    return JSON.parse(el.textContent || '');
                                                } catch (e) {
                                                    console.error('Failed to parse plot data for ' + comp, e);
                                                    return null;
                                                }
                                            }

                                            function __makeScatterChart(canvasId, titleText, datasets, xLabel, yLabel) {
                                                const canvas = document.getElementById(canvasId);
                                                if (!canvas) {
                                                    console.warn('Canvas not found: ' + canvasId);
                                                    return null;
                                                }

                                                // Hide loading indicator
                                                const container = canvas.parentElement;
                                                if (container) {
                                                    const loader = container.querySelector('.chart-loading');
                                                    if (loader) loader.style.display = 'none';
                                                }

                                                const ctx = canvas.getContext('2d');
                                                if (!ctx) {
                                                    console.error('Could not get 2D context for ' + canvasId);
                                                    return null;
                                                }

                                                try {
                                                    console.log('Creating chart for ' + canvasId + ' with ' + datasets.length + ' datasets');
                                                    return new Chart(canvas, {
                                                        type: 'scatter',
                                                        data: {
                                                            datasets: datasets.map(ds => ({
                                                                label: ds.label,
                                                                data: ds.data,
                                                                backgroundColor: ds.backgroundColor || 'rgba(156,163,175,0.45)',
                                                                pointRadius: 2.5,
                                                                pointHoverRadius: 5,
                                                                borderWidth: 0
                                                            }))
                                                        },
                                                        options: {
                                                            responsive: true,
                                                            maintainAspectRatio: false,
                                                            animation: false,
                                                            plugins: {
                                                                title: {
                                                                    display: true,
                                                                    text: titleText,
                                                                    font: { size: 14, weight: '600' }
                                                                },
                                                                legend: {
                                                                    position: 'bottom',
                                                                    labels: {
                                                                        boxWidth: 10,
                                                                        padding: 10,
                                                                        font: { size: 11 }
                                                                    }
                                                                },
                                                                tooltip: {
                                                                    callbacks: {
                                                                        label: function (context) {
                                                                            const x = context.parsed.x !== undefined ? context.parsed.x.toFixed(2) : 'N/A';
                                                                            const y = context.parsed.y !== undefined ? context.parsed.y.toFixed(2) : 'N/A';
                                                                            const label = context.raw && context.raw.label ? context.raw.label : '';
                                                                            const datasetLabel = context.dataset.label;
                                                                            if (label && (datasetLabel === 'Up' || datasetLabel === 'Down')) {
                                                                                return `${label}: (${x}, ${y})`;
                                                                            }
                                                                            return `(${x}, ${y})`;
                                                                        }
                                                                    }
                                                                }
                                                            },
                                                            scales: {
                                                                x: {
                                                                    title: {
                                                                        display: true,
                                                                        text: xLabel,
                                                                        font: { size: 12, weight: '600' }
                                                                    },
                                                                    grid: { color: '#f1f1f1' }
                                                                },
                                                                y: {
                                                                    title: {
                                                                        display: true,
                                                                        text: yLabel,
                                                                        font: { size: 12, weight: '600' }
                                                                    },
                                                                    grid: { color: '#f1f1f1' }
                                                                }
                                                            }
                                                        }
                                                    });
                                                } catch (e) {
                                                    console.error('Chart.js error for ' + canvasId, e);
                                                    if (container) {
                                                        const loader = container.querySelector('.chart-loading');
                                                        if (loader) {
                                                            loader.textContent = 'Error rendering chart';
                                                            loader.style.color = 'red';
                                                            loader.style.display = 'block';
                                                        }
                                                    }
                                                    return null;
                                                }
                                            }

                                            function initSingleDgeChart(compId) {
                                                const data = __getPlotData(compId);
                                                if (!data) return;

                                                // Add small delay to ensure DOM is ready and visible
                                                setTimeout(() => {
                                                    // MA plot
                                                    const maCanvasId = 'ma-' + compId;
                                                    const maCanvas = document.getElementById(maCanvasId);
                                                    if (data.ma && maCanvas && !__dgeCharts.ma[compId]) {
                                                        const ds = [];
                                                        if (data.ma.ns && data.ma.ns.length) ds.push({ label: 'Not Sig', data: data.ma.ns, backgroundColor: 'rgba(156,163,175,0.35)' });
                                                        if (data.ma.down && data.ma.down.length) ds.push({ label: 'Down', data: data.ma.down, backgroundColor: 'rgba(59,130,246,0.6)' });
                                                        if (data.ma.up && data.ma.up.length) ds.push({ label: 'Up', data: data.ma.up, backgroundColor: 'rgba(239,68,68,0.6)' });
                                                        __dgeCharts.ma[compId] = __makeScatterChart(maCanvasId, 'MA Plot', ds, 'logCPM', 'log2FC');
                                                    }

                                                    // Volcano plot
                                                    const volCanvasId = 'volcano-' + compId;
                                                    const volCanvas = document.getElementById(volCanvasId);
                                                    if (data.volcano && volCanvas && !__dgeCharts.volcano[compId]) {
                                                        const ds = [];
                                                        if (data.volcano.ns && data.volcano.ns.length) ds.push({ label: 'Not Sig', data: data.volcano.ns, backgroundColor: 'rgba(156,163,175,0.35)' });
                                                        if (data.volcano.down && data.volcano.down.length) ds.push({ label: 'Down', data: data.volcano.down, backgroundColor: 'rgba(59,130,246,0.6)' });
                                                        if (data.volcano.up && data.volcano.up.length) ds.push({ label: 'Up', data: data.volcano.up, backgroundColor: 'rgba(239,68,68,0.6)' });
                                                        __dgeCharts.volcano[compId] = __makeScatterChart(volCanvasId, 'Volcano Plot', ds, 'log2FC', '-log10(p)');
                                                    }
                                                }, 50);
                                            }

                                            function initDgeCharts() {
                                                if (typeof Chart === 'undefined') {
                                                    console.error('Chart.js not loaded!');
                                                    document.querySelectorAll('.chart-loading').forEach(el => {
                                                        el.textContent = 'Chart.js library failed to load';
                                                        el.style.color = 'red';
                                                    });
                                                    return;
                                                }

                    <% if (typeof dge_figures !== 'undefined' && dge_figures) { %>
                    <% dge_figures.forEach(function (fig, index) { %>
                                                    (function () {
                                                        const compId = <%- JSON.stringify(fig.comparison.replace(/[^a-zA-Z0-9]/g, '_')) %>;
                                                        // Only initialize the first one immediately, others on tab switch
                                                        if (<%= index %> === 0) {
                                                        initSingleDgeChart(compId);
                                                    }
                                                })();
                    <% }); %>
                    <% } %>
                }

                                            if (document.readyState === 'loading') {
                                                document.addEventListener('DOMContentLoaded', initDgeCharts);
                                            } else {
                                                initDgeCharts();
                                            }

                                            // Also call on window load to be absolutely sure
                                            window.addEventListener('load', initDgeCharts);
                                        </script>
                                        <% } %>
                    </div>

                    <!-- Section 11 -->
                    <div id="section-11" class="section">
                        <% let bodySubSec = 4; %>
                        <h4>5.8.<%= bodySubSec++ %>. Gene Ontology (GO) analysis for significant DEG</h4>
                        <p>
                            The Gene Ontology project provides controlled vocabularies of defined terms representing
                            gene product
                            properties. These cover three domains: Cellular Component, the parts of a cell or its
                            extracellular
                            environment; Molecular Function, the elemental activities of a gene product at the molecular
                            level, such
                            as binding or catalysis; and Biological Process, operations or sets of molecular events with
                            a defined
                            beginning and end, pertinent to the functioning of integrated living units: cells, tissues,
                            organs, and
                            organisms. GO was assigned to significant differentially expressed transcripts using
                            Blast2go cli.
                            Single gene can be assigned with multiple GO categories and hence multiple GO terms. The GO
                            domain
                            distribution is shown in table below:
                        </p>

                        <div class="table-wrapper">
                            <div class="table-title">Table 5.8.6: GO Distribution of Significantly Differential
                                expression transcripts</div>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Sample Name</th>
                                        <th>Significant DGE</th>
                                        <th># Seq with GO</th>
                                        <th>Biological Process</th>
                                        <th>Cellular Component</th>
                                        <th>Molecular Function</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% go_distribution.forEach(function(g) { %>
                                        <tr>
                                            <td>
                                                <%= g.combination %>
                                            </td>
                                            <td>
                                                <%= g.sig_dge %>
                                            </td>
                                            <td>
                                                <%= g.sq_go %>
                                            </td>
                                            <td>
                                                <%= g.bp %>
                                            </td>
                                            <td>
                                                <%= g.cc %>
                                            </td>
                                            <td>
                                                <%= g.mf %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <p>
                            <%= static_snippets.go?.deliverables_note || '' %>
                        </p>

                        <% if (func_assets && (func_assets.kegg_results_xlsx || func_assets.kegg_pathway_image_src)) { %>
                            <h4>5.8.<%= bodySubSec++ %>. Pathway analysis for significant DGE</h4>
                            <p>
                                <%= static_snippets.pathway?.intro
                                    || 'Ortholog assignment and mapping of Significant differentially expressed transcripts to the biological pathways were performed using KEGG automatic annotation server (KAAS).'
                                    %>
                            </p>

                            <% if (func_assets && func_assets.kegg_results_preview &&
                                func_assets.kegg_results_preview.length > 0) { %>
                                <div class="table-wrapper">
                                    <div class="table-title">Table 5.8.7: KEGG pathway statistics for Significant
                                        differentially expressed transcripts for
                                        Comparison-1 </div>
                                    <table>
                                        <thead>
                                            <tr>
                                                <% if (func_assets.kegg_results_preview[0]) { %>
                                                    <% func_assets.kegg_results_preview[0].forEach(function(col) { %>
                                                        <th>
                                                            <%= col %>
                                                        </th>
                                                        <% }); %>
                                                            <% } %>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% func_assets.kegg_results_preview.slice(1).forEach(function(row) { %>
                                                <tr>
                                                    <% row.forEach(function(cell) { %>
                                                        <td>
                                                            <%= cell %>
                                                        </td>
                                                        <% }); %>
                                                </tr>
                                                <% }); %>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="table-note"
                                    style="color: var(--secondary-color); font-family: 'Times New Roman', Times, serif; font-weight: bold; margin-top: 15px; margin-bottom: 20px; font-size: 14.5px; line-height: 1.6;">
                                    <div style="margin-bottom: 5px;">Note:</div>
                                    <div
                                        style="padding-left: 20px; text-indent: -20px; margin-bottom: 4px; text-align: justify;">
                                        (a) Non-specific organism pathway hits are obtained in pathway results due to
                                        lenient threshold (bit score: 60) applied in KAAS webserver.
                                    </div>
                                    <div style="padding-left: 20px; text-indent: -20px; text-align: justify;">
                                        (b) Pathway stats for only one comparison has been shown above, however stats and
                                        images for all other combinations has been provided as a part of data deliverables
                                        “07_Significant_DGE_pathways”.
                                    </div>
                                </div>
                                <% } %>

                                    <% if (func_assets && func_assets.kegg_pathway_image_src) { %>
                                        <div class="figure">
                                            <img src="<%= func_assets.kegg_pathway_image_src %>" alt="KEGG pathway" />
                                            <p class="caption">Figure 5.8.5: Example of Comparison-1 KEGG pathway image:
                                                Purple color entry
                                                has been assigned to at
                                                least one gene entry whereas a pink color entry corresponds to an ortholog
                                                table
                                                entry, which
                                                corresponds to a gene that is a part of a functional unit on the pathway</p>
                                        </div>
                                        <% } %>

                                            <% if (pathway_ex_figure_src && (!func_assets ||
                                                !func_assets.kegg_pathway_image_src)) { %>
                                                <div class="figure">
                                                    <img src="<%= pathway_ex_figure_src %>" alt="KEGG pathway example" />
                                                    <p class="caption">Figure 5.8.5: Example of kegg pathway ko image for
                                                        Comparison-1 DGE: Purple color entry has been assigned to at
                                                        least one gene entry whereas a pink color entry corresponds to an
                                                        ortholog table entry, which
                                                        corresponds to a gene that is a part of a functional unit on the
                                                        pathway. </p>
                                                </div>
                                                <% } %>
                        <% } %>
                    </div>

                    <% let contentMainSec = 9; %>

                    <!-- Section Pearson -->
                    <% if (typeof correlation_plots !== 'undefined' && correlation_plots && correlation_plots.length > 0) { %>
                    <div id="section-pearson" class="section">
                        <h2>5.<%= contentMainSec %>. Pearson's correlation coefficient</h2>
                        <p>
                            Pearson's and Spearman's correlation coefficients were calculated to evaluate the similarity between
                            biological replicates and overall sample relationships. Raw count data were first filtered to remove low-expression
                            genes (CPM &gt; 1 in at least two samples). The filtered count matrix was normalized using the
                            <strong>DESeq2</strong> size factor method, followed by variance-stabilizing transformation (VST) to reduce mean-variance
                            dependence.
                        </p>
                        <p>
                            The VST-transformed expression matrix was used to compute Pearson and Spearman correlation matrices using the
                            <strong>cor()</strong> function in R with methods "pearson" and "spearman", respectively. The resulting correlation
                            matrices were visualized as heatmaps using the <strong>heatmap()</strong> function in R to assess clustering
                            patterns and reproducibility among samples.
                        </p>
                        <p>
                            The generated heatmaps represent sample-to-sample correlation based on VST-normalized expression values.
                        </p>
                        <p>
                            This graph for pearson method is also provided in data deliverables folder <strong>"09_Pearson_correlation"</strong>.
                        </p>

                        <% correlation_plots.forEach(function(plot, idx) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 600px;">
                                <img src="<%= plot.src %>" alt="<%= plot.title %>" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= idx + 1 %>: <%= plot.title %> showing clustering patterns based on treatment conditions.</p>
                            </div>
                        <% }); %>
                    </div>
                    <% contentMainSec++; %>
                    <% } %>

                    <!-- Section PCA -->
                    <% if (typeof pca_plots !== 'undefined' && pca_plots && pca_plots.length > 0) { %>
                    <div id="section-pca" class="section">
                        <h2>5.<%= contentMainSec %>. PCA Plot</h2>
                        <p>
                            Principal Component Analysis (PCA) is a powerful statistical technique used to reduce the dimensionality of complex
                            datasets while retaining the most important information. In RNA sequencing (RNA-Seq) data, PCA is particularly
                            valuable for visualizing the relationships and similarities between samples. By transforming the data into a smaller
                            set of principal components (PCs), PCA allows to identify patterns, detect outliers, and assess the overall
                            structure of the data.
                        </p>
                        <p>
                            After performing normalization through DESeq2, PCA was applied to the transformed data (e.g., variance-stabilizing
                            transformation or rlog) to ensure that any observed sample variation is not due to technical artifacts. The PCA plot
                            was derived from DESeq2 output using <strong>plotPCA</strong> function. Output obtained is shown below:
                        </p>

                        <% pca_plots.forEach(function(plot, idx) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                <img src="<%= plot.src %>" alt="<%= plot.title %>" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= idx + 1 %>: <%= plot.title %> showing variance in gene expression across samples, highlighting clustering patterns based on treatment conditions.</p>
                            </div>
                        <% }); %>
                    </div>
                    <% contentMainSec++; %>
                    <% } %>

                    <!-- Section Enrichment -->
                    <% if (func_assets && func_assets.enrichment_plots && func_assets.enrichment_plots.length > 0) { %>
                    <div id="section-enrichment" class="section">
                        <h2>5.<%= contentMainSec %>. Over-representation (or enrichment) analysis</h2>
                        <p>
                            Over-representation (enrichment) analysis is a statistical approach used to identify biological functions,
                            pathways, or processes that are significantly over-represented among a given list of genes compared to a
                            reference background. This helps in interpreting large-scale transcriptomic data by linking differentially
                            expressed genes (DEGs) to specific molecular mechanisms and biological pathways.
                        </p>
                        <p>
                            Functional enrichment analysis was performed using the <strong>clusterProfiler</strong> R package to identify over-represented
                            Gene Ontology (GO) terms and Kyoto Encyclopedia of Genes and Genomes (KEGG) pathways among the significantly
                            differentially expressed genes (DEGs). The functions <strong>enrichGO</strong> and <strong>enrichKEGG</strong> were applied
                            independently to both up-regulated and down-regulated gene sets.
                        </p>
                        <p>
                            Multiple hypothesis testing correction was performed using the <strong>Benjamini-Hochberg (BH)</strong> method, and GO and
                            KEGG terms with pvalueCutoff = 0.05, and qvalueCutoff = 0.2 were considered statistically significant.
                        </p>
                        <p>
                            The results of the enrichment analyses were visualized using <strong>dot plots</strong> and <strong>bar plots</strong>,
                            highlighting the most significantly enriched GO terms and KEGG pathways that may represent key biological processes
                            and molecular mechanisms underlying the observed expression changes.
                        </p>

                        <%
                            let c1_go_up_bar = func_assets.enrichment_plots.find(p => p.comparison.toLowerCase().includes('c1') && p.comparison.toLowerCase().includes('up') && p.type === 'GO' && p.plotType === 'barplot');
                            let c1_go_up_dot = func_assets.enrichment_plots.find(p => p.comparison.toLowerCase().includes('c1') && p.comparison.toLowerCase().includes('up') && p.type === 'GO' && p.plotType === 'dotplot');
                            let c1_go_down_bar = func_assets.enrichment_plots.find(p => p.comparison.toLowerCase().includes('c1') && p.comparison.toLowerCase().includes('down') && p.type === 'GO' && p.plotType === 'barplot');
                            let c1_go_down_dot = func_assets.enrichment_plots.find(p => p.comparison.toLowerCase().includes('c1') && p.comparison.toLowerCase().includes('down') && p.type === 'GO' && p.plotType === 'dotplot');

                            if (!c1_go_up_bar) c1_go_up_bar = func_assets.enrichment_plots.find(p => p.type === 'GO' && p.plotType === 'barplot' && p.src.toLowerCase().includes('up'));
                            if (!c1_go_up_dot) c1_go_up_dot = func_assets.enrichment_plots.find(p => p.type === 'GO' && p.plotType === 'dotplot' && p.src.toLowerCase().includes('up'));
                            if (!c1_go_down_bar) c1_go_down_bar = func_assets.enrichment_plots.find(p => p.type === 'GO' && p.plotType === 'barplot' && p.src.toLowerCase().includes('down'));
                            if (!c1_go_down_dot) c1_go_down_dot = func_assets.enrichment_plots.find(p => p.type === 'GO' && p.plotType === 'dotplot' && p.src.toLowerCase().includes('down'));

                            let figIdx = 1;
                        %>

                        <% if (c1_go_up_bar) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                <img src="<%= c1_go_up_bar.src %>" alt="Upregulated GO Barplot" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= figIdx++ %>: Bar plot of GO enrichment for Comparison1 of up-regulated genes showing the most significantly enriched Gene Ontology (GO) terms in the differentially expressed genes (DEGs).</p>
                            </div>
                        <% } %>
                        <% if (c1_go_up_dot) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                <img src="<%= c1_go_up_dot.src %>" alt="Upregulated GO Dotplot" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= figIdx++ %>: Dot plot of GO enrichment for Comparison1 of up-regulated genes showing the most significantly enriched Gene Ontology (GO) terms in the differentially expressed genes (DEGs).</p>
                            </div>
                        <% } %>
                        <% if (c1_go_down_bar) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                <img src="<%= c1_go_down_bar.src %>" alt="Downregulated GO Barplot" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= figIdx++ %>: Bar plot of GO enrichment for Comparison1 of down-regulated genes showing the most significantly enriched Gene Ontology (GO) terms in the differentially expressed genes (DEGs).</p>
                            </div>
                        <% } %>
                        <% if (c1_go_down_dot) { %>
                            <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                <img src="<%= c1_go_down_dot.src %>" alt="Downregulated GO Dotplot" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                <p class="caption">Figure 5.<%= contentMainSec %>.<%= figIdx++ %>: Dot plot of GO enrichment for Comparison1 of down-regulated genes showing the most significantly enriched Gene Ontology (GO) terms in the differentially expressed genes (DEGs).</p>
                            </div>
                        <% } %>

                        <% if (figIdx === 1) { %>
                            <% func_assets.enrichment_plots.forEach(function(plot) { %>
                                <div class="figure" style="text-align: center; margin: 30px auto; max-width: 700px;">
                                    <img src="<%= plot.src %>" alt="<%= plot.type %> <%= plot.plotType %>" style="width: 100%; height: auto; border: 1px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--card-shadow);" />
                                    <p class="caption">Figure 5.<%= contentMainSec %>.<%= figIdx++ %>: <%= plot.plotType.charAt(0).toUpperCase() + plot.plotType.slice(1) %> of <%= plot.type %> enrichment for <%= plot.comparison %> showing significantly enriched terms.</p>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                    <% contentMainSec++; %>
                    <% } %>

                    <!-- Section 12 Deliverables -->
                    <div id="section-12" class="section">
                        <h2>6. Deliverables</h2>
                        <p>The following deliverables were generated as part of this analysis:</p>
                        <div class="table-wrapper">
                            <div class="table-title">Deliverables Tree</div>
                            <div class="terminal-window">
                                <div class="terminal-header">
                                    <span class="terminal-dot red"></span>
                                    <span class="terminal-dot yellow"></span>
                                    <span class="terminal-dot green"></span>
                                    <span class="terminal-title">
                                        <%= project_id %> — deliverables
                                    </span>
                                </div>
                                <pre><%= deliverables_tree %></pre>
                            </div>
                        </div>
                    </div>

                </div>

                <button id="mobile-toc-toggle" onclick="toggleMobileSidebar()" aria-label="Toggle Navigation">☰</button>

                <script>
                    // Initialize Lucide icons
                    lucide.createIcons();

                    // Toggle Submenu with auto-collapsing siblings at the same nesting depth
                    function toggleSubmenu(parentLi, forceExpand = null) {
                        const submenu = parentLi.querySelector('.toc-submenu');
                        const btn = parentLi.querySelector('.toc-toggle-btn');
                        const row = parentLi.querySelector('.toc-row');

                        if (!submenu) return;

                        const isCurrentlyExpanded = submenu.classList.contains('expanded');
                        const shouldExpand = forceExpand !== null ? forceExpand : !isCurrentlyExpanded;

                        if (shouldExpand) {
                            // Collapse sibling submenus at the same nesting level
                            const siblingLis = Array.from(parentLi.parentElement.children).filter(el => el !== parentLi && el.classList.contains('has-children'));
                            siblingLis.forEach(sib => {
                                const sibSubmenu = sib.querySelector('.toc-submenu');
                                const sibBtn = sib.querySelector('.toc-toggle-btn');
                                const sibRow = sib.querySelector('.toc-row');
                                if (sibSubmenu) sibSubmenu.classList.remove('expanded');
                                if (sibBtn) sibBtn.classList.remove('rotated');
                                if (sibRow) sibRow.classList.remove('active-row');
                            });

                            submenu.classList.add('expanded');
                            if (btn) btn.classList.add('rotated');
                            if (row) row.classList.add('active-row');
                        } else {
                            submenu.classList.remove('expanded');
                            if (btn) btn.classList.remove('rotated');
                            if (row) row.classList.remove('active-row');
                        }
                    }

                    // Collapsible Accordion logic
                    document.querySelectorAll('.toc-toggle-btn').forEach(btn => {
                        btn.addEventListener('click', function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            const parentLi = this.closest('li.has-children');
                            toggleSubmenu(parentLi);
                        });
                    });

                    document.querySelectorAll('.toc-row a').forEach(link => {
                        link.addEventListener('click', function (e) {
                            const parentLi = this.closest('li.has-children');
                            // Toggle accordion on parent link click/tap
                            toggleSubmenu(parentLi);
                        });
                    });

                    // Toggle mobile sidebar
                    function toggleMobileSidebar() {
                        const toc = document.getElementById('TOC');
                        const btn = document.getElementById('mobile-toc-toggle');
                        if (toc.classList.contains('open')) {
                            toc.classList.remove('open');
                            btn.innerHTML = '☰';
                        } else {
                            toc.classList.add('open');
                            btn.innerHTML = '✕';
                        }
                    }

                    // Close sidebar when clicking any TOC link on mobile
                    document.querySelectorAll('#TOC a').forEach(link => {
                        link.addEventListener('click', (e) => {
                            const toc = document.getElementById('TOC');
                            const btn = document.getElementById('mobile-toc-toggle');
                            // Collapse mobile sidebar only when tapping a leaf/final section link (not a parent toggle link)
                            if (!link.closest('.toc-row')) {
                                if (toc.classList.contains('open')) {
                                    toc.classList.remove('open');
                                    btn.innerHTML = '☰';
                                }
                            }

                            // Immediately highlight clicked link
                            document.querySelectorAll('#TOC a').forEach(a => a.classList.remove('active'));
                            document.querySelectorAll('#TOC .toc-row').forEach(row => row.classList.remove('active-row'));

                            const isMainLink = link.closest('.toc-row') || (link.parentElement.parentElement === document.querySelector('#TOC > ul'));
                            if (isMainLink) {
                                link.classList.add('active');
                                const parentRow = link.closest('.toc-row');
                                if (parentRow) parentRow.classList.add('active-row');
                            } else {
                                // It is a sub-link. Highlight the sub-link and the parent main link/row.
                                link.classList.add('active');
                                const parentLi = link.closest('#TOC > ul > li.has-children');
                                if (parentLi) {
                                    const mainA = parentLi.querySelector('.toc-row a');
                                    if (mainA) mainA.classList.add('active');
                                    const mainRow = parentLi.querySelector('.toc-row');
                                    if (mainRow) mainRow.classList.add('active-row');
                                }
                            }
                        });
                    });

                    // Scroll Spy active navigation highlight logic using getBoundingClientRect
                    const sections = document.querySelectorAll('.main-container .section');
                    const navLinks = document.querySelectorAll('#TOC > ul > li > a, #TOC > ul > li > .toc-row > a');

                    window.addEventListener('scroll', () => {
                        let current = '';
                        sections.forEach(section => {
                            const rect = section.getBoundingClientRect();
                            // Check if the section is occupying the top-half of the screen
                            if (rect.top <= window.innerHeight * 0.6) {
                                current = section.getAttribute('id');
                            }
                        });

                        if (current) {
                            let mappedCurrent = current;
                            const match = current.match(/^section-(\d+)$/);
                            if (match) {
                                const secNum = parseInt(match[1], 10);
                                if (secNum >= 5 && secNum <= 11) {
                                    mappedCurrent = 'section-5';
                                }
                            }
                            navLinks.forEach(link => {
                                link.classList.remove('active');
                                const parentRow = link.closest('.toc-row');
                                if (parentRow) parentRow.classList.remove('active-row');

                                if (link.getAttribute('href') === '#' + mappedCurrent) {
                                    link.classList.add('active');
                                    if (parentRow) parentRow.classList.add('active-row');
                                }
                            });
                        }
                    }, { capture: true, passive: true });

                    // Trigger once on load
                    window.dispatchEvent(new Event('scroll'));

                    // DGE Chart
                    const dgeCtx = document.getElementById('dgeChart');
                    if (dgeCtx && <%- JSON.stringify(dge_chart_labels) %>.length > 0) {
                        new Chart(dgeCtx, {
                            type: 'bar',
                            data: {
                                labels: <%- JSON.stringify(dge_chart_labels) %>,
                                datasets: [
                                    {
                                        label: 'Upregulated',
                                        data: <%- JSON.stringify(dge_chart_up) %>,
                                        backgroundColor: 'rgba(220, 38, 38, 0.7)',
                                        borderColor: 'rgba(220, 38, 38, 1)',
                                        borderWidth: 1
                                    },
                                    {
                                        label: 'Downregulated',
                                        data: <%- JSON.stringify(dge_chart_down) %>,
                                        backgroundColor: 'rgba(49, 130, 206, 0.7)',
                                        borderColor: 'rgba(49, 130, 206, 1)',
                                        borderWidth: 1
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        display: true
                                    }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        title: {
                                            display: true,
                                            text: 'Number of Genes'
                                        }
                                    }
                                }
                            }
                        });
                    }

                    // Scroll Progress Indicator Logic
                    window.addEventListener('scroll', () => {
                        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
                        const progressEl = document.getElementById('scroll-progress');
                        if (progressEl) progressEl.style.width = scrolled + '%';
                    });
                </script>

</body>

</html>