<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title> Unigenome <%= project_id %>
    </title>

    <!-- Dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=Inter:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">

    <style>
        :root {
            /* Brand palette — refined from the original Unigenome identity */
            --primary-color: #E06D1B;
            --primary-hover: #C25A0F;
            --primary-soft: #FDF1E7;
            --secondary-color: #0F2547;
            --secondary-soft: #EEF2F8;
            --accent-color: #2B6CB0;
            --accent-soft: #E8F1FB;

            --text-main: #1C2430;
            --text-muted: #5B6B7F;
            --text-faint: #8A97A8;

            --bg-body: #F3F4F7;
            --bg-sidebar: rgba(255, 255, 255, 0.88);
            --bg-paper: #FFFFFF;
            --border-color: #E3E7ED;
            --border-soft: #EDF0F4;

            --success-color: #15803D;
            --success-soft: #E9F7EF;
            --warn-color: #B7791F;
            --warn-soft: #FCF3DE;
            --fail-color: #B42318;
            --fail-soft: #FCEAE8;

            --card-shadow: 0 1px 2px rgba(15, 37, 71, 0.04), 0 8px 24px -8px rgba(15, 37, 71, 0.10);
            --card-shadow-hover: 0 1px 2px rgba(15, 37, 71, 0.05), 0 16px 36px -10px rgba(15, 37, 71, 0.16);
            --glass-blur: blur(16px);
            --radius-sm: 6px;
            --radius-md: 10px;
            --radius-lg: 16px;

            --font-serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
            --font-ui: 'Outfit', system-ui, sans-serif;
            --font-mono: 'JetBrains Mono', 'Courier New', monospace;
        }

        * {
            box-sizing: border-box;
        }

        ::selection {
            background: rgba(224, 109, 27, 0.18);
        }

        body {
            font-family: var(--font-serif);
            font-size: 12.5px;
            line-height: 1.7;
            color: var(--text-main);
            background-color: var(--bg-body);
            background-image:
                radial-gradient(circle at 12% 8%, rgba(43, 108, 176, 0.05), transparent 32%),
                radial-gradient(circle at 88% 92%, rgba(224, 109, 27, 0.05), transparent 32%);
            margin: 0;
            padding-left: 292px;
            transition: background-color 0.3s ease, color 0.3s ease, padding-left 0.3s ease;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        h1,
        h2,
        h3,
        h4,
        .ui-font {
            font-family: var(--font-serif);
            color: var(--secondary-color);
            letter-spacing: -0.01em;
        }

        p {
            margin: 0 0 1.25rem 0;
            text-align: justify;
            hyphens: auto;
            font-size: 12.5px;
            color: var(--text-main);
        }

        strong {
            font-weight: 600;
            color: var(--secondary-color);
        }

        a {
            color: var(--accent-color);
        }

        .section {
            scroll-margin-top: 32px;
        }

        /* ============ Fixed TOC Sidebar (Screen Only) ============ */
        #TOC {
            font-family: var(--font-ui);
            position: fixed;
            top: 0;
            left: 0;
            width: 292px;
            height: 100vh;
            overflow-y: auto;
            background: var(--bg-sidebar);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-right: 1px solid var(--border-color);
            padding: 36px 0 28px;
            z-index: 1000;
            transition: transform 0.3s ease;
            scrollbar-width: thin;
        }

        #TOC::-webkit-scrollbar {
            width: 6px;
        }

        #TOC::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }

        /* Mobile Sidebar toggle button */
        #mobile-toc-toggle {
            display: none;
            position: fixed;
            bottom: 22px;
            right: 22px;
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(145deg, var(--primary-color), var(--primary-hover));
            color: #fff;
            box-shadow: 0 10px 24px -6px rgba(224, 109, 27, 0.55);
            border: none;
            cursor: pointer;
            z-index: 1010;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        #mobile-toc-toggle:hover {
            transform: translateY(-2px);
        }

        .toc-header {
            padding: 0 28px 22px 28px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 18px;
        }

        .toc-header img {
            display: block;
            max-width: 100%;
            height: auto;
        }

        .toc-header .toc-tag {
            display: inline-block;
            margin-top: 14px;
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--accent-color);
            background: var(--accent-soft);
            padding: 5px 10px;
            border-radius: 20px;
        }

        #TOC ul {
            list-style: none;
            padding: 0 14px;
            margin: 0;
        }

        #TOC li a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            margin: 2px 0;
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border-left: 3px solid transparent;
            transition: all 0.18s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #TOC li a:hover {
            color: var(--secondary-color);
            background: var(--secondary-soft);
        }

        #TOC li a.active {
            color: var(--primary-color);
            background: var(--primary-soft);
            border-left: 3px solid var(--primary-color);
            font-weight: 700;
        }

        /* ============ Content Area ============ */
        .main-container {
            margin: 40px auto;
            padding: 0 40px;
            max-width: 1080px;
            background-color: transparent;
            box-shadow: none;
            border: none;
        }

        /* ============ Responsive ============ */
        @media screen and (max-width: 1200px) {
            body {
                padding-left: 0;
            }

            #TOC {
                transform: translateX(-100%);
                box-shadow: 0 0 40px rgba(15, 37, 71, 0.18);
            }

            #TOC.open {
                transform: translateX(0);
            }

            #mobile-toc-toggle {
                display: flex;
            }

            .main-container {
                margin: 20px auto;
                padding: 0 20px;
                max-width: none;
            }

            .section {
                padding: 32px 26px;
            }
        }

        @media screen and (max-width: 768px) {
            .main-container {
                margin: 14px auto;
                padding: 0 12px;
            }

            .section {
                padding: 26px 18px;
                border-radius: var(--radius-md);
            }

            .cover-page {
                padding: 48px 22px;
            }

            .cover-title {
                font-size: 24px !important;
                letter-spacing: 0.02em !important;
            }

            .cover-subtitle {
                font-size: 16px !important;
            }

            table {
                font-size: 11px;
            }

            .tapestation-grid {
                gap: 24px;
            }
        }

        @media screen and (max-width: 480px) {
            #TOC {
                width: 86%;
                max-width: 320px;
            }
        }

        /* ============ Cover Page ============ */
        .cover-page {
            height: auto;
            min-height: 82vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            text-align: center;
            padding: 76px 56px;
            box-sizing: border-box;
            page-break-after: always;
            position: relative;
            background: linear-gradient(180deg, #FFFFFF 0%, #FCFDFE 100%);
            border-radius: var(--radius-lg);
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            margin-bottom: 40px;
            overflow: hidden;
        }

        .cover-page::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--secondary-color) 0%, var(--accent-color) 48%, var(--primary-color) 100%);
        }

        .cover-logo {
            max-width: 300px;
            margin-bottom: 40px;
        }

        .cover-title {
            font-family: var(--font-serif);
            font-size: 34px;
            font-weight: 700;
            color: var(--secondary-color);
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .cover-subtitle {
            font-family: var(--font-serif);
            font-size: 21px;
            font-weight: 500;
            color: var(--text-main);
            margin-bottom: 34px;
            line-height: 1.4;
        }

        .cover-details {
            font-family: var(--font-ui);
            font-size: 14px;
            color: var(--primary-color);
            font-weight: 700;
            letter-spacing: 0.02em;
            margin-bottom: 56px;
        }

        .submitted-by {
            margin-top: 22px;
            color: var(--text-muted);
            font-family: var(--font-ui);
            font-size: 12px;
            line-height: 1.55;
        }

        .submitted-to {
            margin-top: auto;
            color: var(--secondary-color);
            font-weight: 700;
            font-family: var(--font-ui);
            font-size: 16px;
        }

        /* ============ Tabbed View ============ */
        .tab-container {
            margin: 22px 0 0;
            border-bottom: 2px solid var(--border-color);
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            font-family: var(--font-ui);
        }

        .tab-button {
            padding: 11px 22px;
            cursor: pointer;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            border-radius: 6px 6px 0 0;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.2s ease;
            font-size: 13.5px;
            font-family: var(--font-ui);
        }

        .tab-button:hover {
            color: var(--primary-color);
            background: var(--primary-soft);
        }

        .tab-button.active {
            color: var(--primary-color);
            border-bottom: 3px solid var(--primary-color);
            background: var(--primary-soft);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.35s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Generic card used inside tab panels */
        .card {
            background: var(--bg-paper);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            transition: box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .card:hover {
            box-shadow: var(--card-shadow);
        }

        /* ============ Typography ============ */
        h1.title {
            font-size: 28px;
            margin-top: 0;
            margin-bottom: 10px;
            font-weight: 700;
            color: var(--secondary-color);
        }

        .subtitle {
            font-family: var(--font-ui);
            font-size: 15px;
            color: var(--text-muted);
            margin-bottom: 30px;
            font-weight: 400;
        }

        .section {
            scroll-margin-top: 32px;
            background-color: var(--bg-paper);
            border-radius: var(--radius-lg);
            padding: 48px 56px;
            margin-bottom: 32px;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border-color);
            page-break-inside: avoid;
            position: relative;
            transition: box-shadow 0.25s ease;
        }

        h2 {
            font-family: var(--font-ui);
            font-size: 12.5px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--secondary-color);
            padding-bottom: 14px;
            margin-top: 0;
            margin-bottom: 28px;
            display: flex;
            align-items: baseline;
            gap: 10px;
            border-bottom: none;
            position: relative;
            page-break-after: avoid;
        }

        h2::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            width: 100%;
            height: 1px;
            background: var(--border-color);
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            bottom: -1px;
            width: 48px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
            border-radius: 2px;
        }

        h3 {
            font-family: var(--font-serif);
            font-size: 16px;
            font-weight: 600;
            margin-top: 32px;
            margin-bottom: 14px;
            color: var(--secondary-color);
            page-break-after: avoid;
        }

        h4 {
            font-family: var(--font-ui);
            font-size: 12.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 24px;
            margin-bottom: 12px;
            color: var(--accent-color);
        }

        /* ============ Tables ============ */
        .table-wrapper {
            overflow-x: auto;
            margin: 18px 0 30px 0;
            page-break-inside: avoid;
            border-radius: var(--radius-md);
        }

        .table-title {
            font-family: var(--font-ui);
            font-weight: 700;
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 10px;
            color: var(--accent-color);
        }

        table {
            width: 100%;
            max-width: 100%;
            border-spacing: 0;
            border-collapse: separate;
            border-radius: var(--radius-md);
            overflow: hidden;
            border: 1px solid var(--border-color);
            font-family: var(--font-ui);
            font-size: 12px;
            box-shadow: 0 1px 2px rgba(15, 37, 71, 0.03);
        }

        table th {
            padding: 12px 14px;
            background-color: var(--secondary-color);
            background-image: linear-gradient(180deg, #16315A, var(--secondary-color));
            color: #fff;
            border: none;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            text-align: left;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-size: 11px;
        }

        table th:last-child {
            border-right: none;
        }

        table td {
            padding: 10px 14px;
            border-top: 1px solid var(--border-soft);
            border-right: 1px solid var(--border-soft);
            vertical-align: middle;
            transition: background-color 0.15s ease;
        }

        table td:last-child {
            border-right: none;
        }

        table tr:nth-of-type(even) td {
            background-color: #FAFBFD;
        }

        table tr:hover td {
            background-color: var(--accent-soft);
        }

        /* ============ Status badges ============ */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-family: var(--font-ui);
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 20px;
            line-height: 1.4;
        }

        .status-badge::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

        .status-pass {
            color: var(--success-color);
            background: var(--success-soft);
        }

        .status-warn {
            color: var(--warn-color);
            background: var(--warn-soft);
        }

        .status-fail {
            color: var(--fail-color);
            background: var(--fail-soft);
        }

        /* ============ Figures ============ */
        .figure {
            margin: 28px 0;
            text-align: center;
            background: var(--bg-paper);
            border: 1px solid var(--border-soft);
            border-radius: var(--radius-md);
            padding: 18px;
            page-break-inside: avoid;
        }

        .figure img {
            max-width: 100%;
            height: auto;
            border-radius: var(--radius-sm);
        }

        .caption {
            font-family: var(--font-ui);
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 12px;
            font-style: normal;
            font-weight: 600;
            letter-spacing: 0.01em;
        }

        /* ============ Info Box ============ */
        .info-box {
            padding: 18px 22px;
            margin-bottom: 25px;
            border-left: 4px solid var(--primary-color);
            background: var(--primary-soft);
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            color: var(--text-main);
        }

        /* ============ TapeStation Cards ============ */
        .tapestation-grid {
            display: flex;
            flex-direction: column;
            gap: 32px;
            margin: 28px 0;
        }

        .tapestation-card {
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 22px;
            text-align: center;
            background: linear-gradient(180deg, #FFFFFF 0%, #FCFDFE 100%);
            box-shadow: var(--card-shadow);
            page-break-inside: avoid;
            width: 100%;
            box-sizing: border-box;
            transition: box-shadow 0.25s ease, transform 0.25s ease;
        }

        .tapestation-card:hover {
            box-shadow: var(--card-shadow-hover);
            transform: translateY(-2px);
        }

        .tapestation-card img {
            width: 100%;
            max-width: 100%;
            height: auto;
            max-height: 500px;
            object-fit: contain;
            border-bottom: 1px solid var(--border-soft);
            padding-bottom: 14px;
            margin-bottom: 14px;
            border-radius: var(--radius-sm);
            background: #fff;
        }

        .tapestation-card span {
            font-family: var(--font-ui);
            font-size: 13px;
            font-weight: 600;
            color: var(--secondary-color);
            display: block;
        }

        .mono {
            font-family: var(--font-mono);
            font-size: 11px;
        }

        .confidential {
            font-family: var(--font-ui);
            color: var(--text-faint);
            font-size: 10px;
            margin-top: 5px;
            text-align: right;
        }

        /* ============ Terminal-style block (Deliverables tree) ============ */
        .terminal-window {
            background: #0F1620;
            border-radius: var(--radius-md);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            border: 1px solid #1E2A38;
        }

        .terminal-header {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 16px;
            background: #182230;
            border-bottom: 1px solid #232F3E;
        }

        .terminal-dot {
            width: 11px;
            height: 11px;
            border-radius: 50%;
            display: inline-block;
        }

        .terminal-dot.red {
            background: #FF5F56;
        }

        .terminal-dot.yellow {
            background: #FFBD2E;
        }

        .terminal-dot.green {
            background: #27C93F;
        }

        .terminal-title {
            font-family: var(--font-ui);
            font-size: 11px;
            color: #8A97A8;
            margin-left: 6px;
            letter-spacing: 0.02em;
        }

        .terminal-window pre {
            margin: 0;
            background: transparent !important;
            color: #D7E0EA;
            padding: 20px 22px !important;
            font-family: var(--font-mono) !important;
            font-size: 11.5px;
            line-height: 1.7;
            overflow-x: auto;
            border-radius: 0 !important;
        }

        /* ============ Print Formatting ============ */
        @media print {
            @page {
                size: A4;
                margin: 20mm 20mm 20mm 20mm;
            }

            @page :first {
                margin: 0;
            }

            body {
                background-color: #fff !important;
                background-image: none !important;
                font-size: 10.5pt;
                line-height: 1.55;
                margin: 0;
                padding: 0 !important;
                width: 100% !important;
            }

            #TOC,
            #mobile-toc-toggle {
                display: none !important;
            }

            .main-container {
                margin: 0 auto;
                padding: 0;
                width: 100%;
                max-width: none;
                background: transparent;
                box-shadow: none;
                border-radius: 0;
                border: none;
            }

            .section {
                box-shadow: none;
                border: none;
                padding: 0;
            }

            .table-wrapper,
            table,
            .figure,
            .tapestation-card,
            .terminal-window {
                break-inside: avoid;
            }

            thead {
                display: table-header-group;
            }

            h2 {
                page-break-after: avoid;
                page-break-before: auto;
                margin-top: 30px;
            }

            h3 {
                page-break-after: avoid;
                page-break-before: auto;
            }

            .section {
                page-break-inside: avoid;
            }

            .cover-page {
                page-break-after: always;
                box-shadow: none;
                border: none;
            }
        }

        /* Collapsible TOC sidebar styles */
        #TOC ul {
            list-style: none;
            padding: 0 14px;
            margin: 0;
        }

        #TOC li {
            margin: 4px 0;
            position: relative;
        }

        .toc-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            border-radius: var(--radius-sm);
            transition: all 0.2s ease;
        }

        .toc-row:hover {
            background: var(--secondary-soft);
        }

        .toc-row.active-row {
            background: var(--primary-soft);
        }

        #TOC li a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            width: 100%;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border-left: 3px solid transparent;
            transition: all 0.18s cubic-bezier(0.4, 0, 0.2, 1);
            box-sizing: border-box;
        }

        #TOC li a:hover {
            color: var(--secondary-color);
        }

        #TOC li a.active {
            color: var(--primary-color);
            border-left: 3px solid var(--primary-color);
            font-weight: 700;
        }

        /* Toggle Button styling */
        .toc-toggle-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            cursor: pointer;
            color: var(--text-muted);
            border-radius: 50%;
            margin-right: 8px;
            transition: all 0.2s ease;
        }

        .toc-toggle-btn:hover {
            background: var(--border-color);
            color: var(--secondary-color);
        }

        .toc-toggle-btn.rotated {
            transform: rotate(180deg);
            color: var(--primary-color);
        }

        /* Submenu container */
        .toc-submenu {
            display: none;
            list-style: none;
            padding: 0 0 0 16px !important;
            margin: 4px 0 0 0;
            border-left: 1px dashed var(--border-color);
        }

        .toc-submenu.expanded {
            display: block;
        }

        /* Submenu items */
        .toc-submenu li a {
            padding: 8px 14px;
            font-size: 12px;
            font-weight: 400;
        }

        .toc-submenu li a.active {
            font-weight: 600;
        }

        /* Inline Table of Contents on the main page */
        .inline-toc {
            background: var(--bg-paper);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 40px 56px !important;
            box-shadow: var(--card-shadow);
            margin-bottom: 40px;
            page-break-after: always;
        }

        .inline-toc h2 {
            font-family: var(--font-ui);
            font-size: 20px;
            font-weight: 700;
            color: var(--secondary-color);
            text-align: center;
            margin-top: 0;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            border: none;
            display: block;
        }

        .inline-toc h2::after, .inline-toc h2::before {
            display: none;
        }

        .toc-list {
            list-style: none;
            padding: 0;
            margin: 0;
            font-family: var(--font-ui);
        }

        .toc-list li {
            margin: 8px 0;
        }

        .toc-list li a {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            text-decoration: none;
            color: var(--text-main);
            font-size: 13.5px;
            transition: color 0.15s ease;
        }

        .toc-list li a:hover {
            color: var(--primary-color);
        }

        .toc-list li a:hover .title {
            text-decoration: underline;
        }

        .toc-list li a .title {
            order: 1;
            background: var(--bg-paper);
            padding-right: 8px;
        }

        .toc-list li a .page {
            order: 3;
            background: var(--bg-paper);
            padding-left: 8px;
            font-weight: 600;
            color: var(--secondary-color);
        }

        .toc-list li a .dots {
            order: 2;
            flex-grow: 1;
            border-bottom: 2px dotted #c5cbd5;
            margin: 0 4px;
            position: relative;
            top: -4px;
        }

        /* Indentation levels */
        .toc-list li.level-1 {
            font-weight: 600;
            margin-top: 14px;
        }
        
        .toc-list li.level-1 a .title {
            color: var(--secondary-color);
        }

        .toc-list li.level-2 {
            padding-left: 20px;
            font-size: 13px;
        }

        .toc-list li.level-3 {
            padding-left: 40px;
            font-size: 12.5px;
            font-style: italic;
        }

        /* Make first column bold in all tables */
        table tbody td:first-child {
            font-weight: 600;
            color: var(--secondary-color);
        }

        /* Scroll Progress Bar */
        #scroll-progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: transparent;
            z-index: 2000;
        }
        #scroll-progress {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary-color) 0%, var(--accent-color) 100%);
            transition: width 0.05s ease-out;
        }
    </style>
</head>

