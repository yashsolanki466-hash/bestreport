                            </div>
                            <div style="height: 350px; padding: 15px; position: relative;">
                                <div class="chart-loading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #999; font-size: 12px;">Loading chart...</div>
                                <% if (fig.ma_plot_data || fig.volcano_plot_data) { %>
                                    <script type="application/json" id="plotdata-<%= sanitizedComp %>"><%- fig.plot_data_json %></script>
                                <% } %>

                                <% if (fig.ma_plot_data) { %>
                                <canvas id="ma-<%= sanitizedComp %>" class="ma-plot-canvas" style="display: block; width: 100%; height: 100%;"></canvas>
                                <% } else { %>
                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                    <span style="color: #666;">MA Plot data not available</span>
                                </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Volcano Plot -->
                        <div class="card" style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                            <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-weight: 600; font-size: 12px;">Volcano Plot</span>
                            </div>
                            <div style="height: 350px; padding: 15px; position: relative;">
                                <div class="chart-loading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #999; font-size: 12px;">Loading chart...</div>
                                <% if (fig.volcano_plot_data) { %>
                                <canvas id="volcano-<%= sanitizedComp %>" class="volcano-plot-canvas" style="display: block; width: 100%; height: 100%;"></canvas>
                                <% } else { %>
                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                    <span style="color: #666;">Volcano Plot data not available</span>
                                </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Heatmap -->
                    <% if (fig.heatmap_png_src) { %>
