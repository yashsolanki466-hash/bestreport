            <h3>3.3. Quantity and quality check (QC) of library on Agilent Tape Station 4150</h3>
            <p><%= static_snippets.wet_lab && static_snippets.wet_lab.library_qc ? static_snippets.wet_lab.library_qc : 'Library QC was performed using Agilent Tape Station 4150.' %></p>

            <h3>3.4. Cluster Generation and Sequencing</h3>
            <p><%= static_snippets.wet_lab && static_snippets.wet_lab.cluster_generation ? static_snippets.wet_lab.cluster_generation : 'Cluster generation and sequencing was performed on Illumina platform.' %></p>

            <h3>3.5. Results: RNA QC on 1.0% agarose gel</h3>
            <% if (gel_image_src) { %>
                <div class="figure">
                    <img src="<%= gel_image_src %>" alt="RNA QC Gel">
                    <div class="caption">Figure 3.1: RNA QC on 1.0% agarose gel</div>
                </div>
            <% } %>

            <h3>3.6. Quantification using Qubit 4.0 Fluorometer</h3>
            <% if (qubit_data && qubit_data.length > 0) { %>
                <div class="table-wrapper">
                    <div class="table-title">Table 3.1: Qubit Quantification Data</div>
                    <table>
                        <thead>
                            <tr>
                                <% Object.keys(qubit_data[0]).forEach(function(key) { %>
                                    <th><%= key %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% qubit_data.forEach(function(q) { %>
                                <tr>
                                    <% Object.values(q).forEach(function(val) { %>
                                        <td><%= val %></td>
                                    <% }); %>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>

            <% if (lane_mapping && lane_mapping.headers && lane_mapping.rows) { %>
                <div class="table-wrapper">
                    <div class="table-title">Table 3.2: Gel Lane Mapping</div>
                    <table>
                        <thead>
                            <tr>
                                <% lane_mapping.headers.forEach(function(header) { %>
                                    <th><%= header %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% lane_mapping.rows.forEach(function(row) { %>
                                <tr>
                                    <% row.forEach(function(cell) { %>
                                        <td><%= cell %></td>
                                    <% }); %>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

