                            <% if (library_sizes && library_sizes[idx]) { %>
                                <span style="font-size: 13px; font-weight: 600; color: var(--text-muted); margin-top: 4px;">Peak Size: <%= library_sizes[idx] %> bp</span>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            <% } %>

