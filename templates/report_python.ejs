                        </div>
                    <% } %>

                    <% if (plotData && plotData.volcano && (plotData.volcano.up.length > 0 || plotData.volcano.down.length > 0 || plotData.volcano.ns.length > 0)) { %>
                        <h3>5.8.2. Volcano plot for <%= fig.comparison %></h3>
                        <div class="figure">
                            <canvas id="volcano-chart-<%= figIdx %>" style="width: 100%; max-width: 800px; height: 500px;"></canvas>
                            <div class="caption">Figure <%= 5.4 + figIdx * 0.1 + 0.2 %>. Volcano plot for <%= fig.comparison %></div>
                        </div>
                    <% } %>
                <% }); %>
            <% } %>
        </div>

        <div id="section-11" class="section">
            <h2>5.8.4-6. Enrichment Analysis</h2>

            <h3>5.8.4. Gene Ontology (GO) analysis for significant DEG</h3>
            <% if (func_assets && func_assets.go_results_preview && func_assets.go_results_preview.length > 0) { %>
                <div class="table-wrapper">
                    <div class="table-title">Table 5.7: Top GO Terms</div>
                    <table>
                        <thead>
                            <tr>
                                <% func_assets.go_results_preview[0].forEach(function(col, colIdx) { %>
                                    <th><%= col %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% func_assets.go_results_preview.slice(1, 16).forEach(function(row) { %>
                                <tr>
                                    <% row.forEach(function(cell) { %>
                                        <td><%= cell %></td>
                                    <% }); %>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>

            <h3>5.8.5. Pathway analysis for significant DGE</h3>
            <% if (pathway_stats && pathway_stats.length > 0) { %>
                <div class="table-wrapper">
                    <div class="table-title">Table 5.8: Top Enriched Pathways</div>
                    <table>
                        <thead>
                            <tr>
                                <% Object.keys(pathway_stats[0]).forEach(function(key) { %>
                                    <th><%= key %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% pathway_stats.slice(0, 10).forEach(function(stat) { %>
                                <tr>
                                    <% Object.values(stat).forEach(function(val) { %>
                                        <td><%= val %></td>
                                    <% }); %>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>

            <% if (func_assets && func_assets.kegg_pathway_image_src) { %>
                <div class="figure">
                    <img src="<%= func_assets.kegg_pathway_image_src %>" alt="KEGG Pathway">
                    <div class="caption">Figure 5.4: Example Pathway Analysis</div>
                </div>
            <% } else if (pathway_ex_figure_src) { %>
                <div class="figure">
                    <img src="<%= pathway_ex_figure_src %>" alt="Pathway Example">
                    <div class="caption">Figure 5.4: Example Pathway Analysis</div>
                </div>
            <% } %>

            <h3>5.8.6. Over-representation (or enrichment) analysis</h3>
            <% if (func_assets && func_assets.dotplot_image_src) { %>
                <div class="figure">
                    <img src="<%= func_assets.dotplot_image_src %>" alt="Dotplot">
                    <div class="caption">Figure 5.5: Enrichment Dot Plot</div>
                </div>
            <% } %>
            <% if (func_assets && func_assets.barplot_image_src) { %>
                <div class="figure">
                    <img src="<%= func_assets.barplot_image_src %>" alt="Barplot">
                    <div class="caption">Figure 5.6: Enrichment Bar Plot</div>
                </div>
            <% } %>
            <% if (func_assets && func_assets.enrichment_image_src) { %>
                <div class="figure">
                    <img src="<%= func_assets.enrichment_image_src %>" alt="Enrichment">
                    <div class="caption">Figure 5.7: Enrichment Plot</div>
                </div>
            <% } %>
        </div>

        <div id="section-12" class="section">
            <h2>6. Deliverables</h2>
            <% if (deliverables_tree) { %>
                <div class="info-box">
                    <pre style="font-family: 'Courier New', monospace; font-size: 13px; margin: 0; white-space: pre-wrap; word-wrap: break-word;"><%= deliverables_tree %></pre>
                </div>
            <% } %>
        </div>

    </div>

    <script>
        // Initialize Lucide icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        // Mobile TOC toggle
        const mobileToggle = document.getElementById('mobile-toc-toggle');
        const toc = document.getElementById('TOC');

        if (mobileToggle && toc) {
            mobileToggle.addEventListener('click', () => {
                toc.classList.toggle('open');
                const icon = mobileToggle.querySelector('[data-lucide]');
                if (icon) {
                    icon.setAttribute('data-lucide', toc.classList.contains('open') ? 'x' : 'menu');
                    if (typeof lucide !== 'undefined') {
                        lucide.createIcons();
                    }
                }
            });
        }

        // TOC submenu toggling
        document.querySelectorAll('.toc-toggle-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const submenu = this.closest('.has-children').querySelector('.toc-submenu');
                const row = this.closest('.toc-row');
                if (submenu) {
                    submenu.classList.toggle('expanded');
                    this.classList.toggle('rotated');
                    if (row) {
                        row.classList.toggle('active-row');
                    }
                }
            });
        });

        // Active section highlighting
        const sections = document.querySelectorAll('.section[id]');
        const tocLinks = document.querySelectorAll('#TOC li a[href^="#"]');

        const observerOptions = {
            rootMargin: '-20% 0px -70% 0px',
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    tocLinks.forEach(link => {
                        link.classList.remove('active');
                        const parentLi = link.closest('li');
                        if (parentLi) {
                            const row = parentLi.querySelector('.toc-row');
                            if (row) {
                                row.classList.remove('active-row');
                            }
                        }
                    });
                    const activeLink = document.querySelector(`#TOC li a[href="#${entry.target.id}"]`);
                    if (activeLink) {
                        activeLink.classList.add('active');
                        const parentLi = activeLink.closest('li');
                        if (parentLi) {
                            const row = parentLi.querySelector('.toc-row');
                            const parentSubmenu = parentLi.closest('.toc-submenu');
                            if (row) {
                                row.classList.add('active-row');
                            }
                            if (parentSubmenu) {
                                parentSubmenu.classList.add('expanded');
                                const parentToggle = parentSubmenu.closest('.has-children').querySelector('.toc-toggle-btn');
                                if (parentToggle) {
                                    parentToggle.classList.add('rotated');
                                }
                            }
                        }
                    }
                }
            });
        }, observerOptions;

        sections.forEach(section => {
            observer.observe(section);
        });

        <% if (dge_figures && dge_figures.length > 0) { %>
            <% dge_figures.forEach(function(fig, figIdx) { %>
                <% if (fig.plot_data_json) { %>
                    const plotData_<%= figIdx %> = <%= fig.plot_data_json %>;

                    // MA Plot
                    if (plotData_<%= figIdx %>.ma && (plotData_<%= figIdx %>.ma.up.length > 0 || plotData_<%= figIdx %>.ma.down.length > 0 || plotData_<%= figIdx %>.ma.ns.length > 0)) {
                        const maCtx_<%= figIdx %> = document.getElementById('ma-chart-<%= figIdx %>');
                        if (maCtx_<%= figIdx %>) {
                            const maChart_<%= figIdx %> = new Chart(maCtx_<%= figIdx %>.getContext('2d'), {
                                type: 'scatter',
                                data: {
                                    datasets: [
                                        {
                                            label: 'Up-regulated',
                                            data: plotData_<%= figIdx %>.ma.up.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(239, 68, 68, 0.6)',
                                            pointRadius: 3,
                                            pointHoverRadius: 6
                                        },
                                        {
                                            label: 'Down-regulated',
                                            data: plotData_<%= figIdx %>.ma.down.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(59, 130, 246, 0.6)',
                                            pointRadius: 3,
                                            pointHoverRadius: 6
                                        },
                                        {
                                            label: 'Not significant',
                                            data: plotData_<%= figIdx %>.ma.ns.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(156, 163, 175, 0.4)',
                                            pointRadius: 2,
                                            pointHoverRadius: 4
                                        }
                                    ]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: {
                                        legend: {
                                            position: 'top',
                                        },
                                        title: {
                                            display: true,
                                            text: 'MA Plot - <%= fig.comparison %>'
                                        },
                                        tooltip: {
                                            callbacks: {
                                                label: function(context) {
                                                    const point = plotData_<%= figIdx %>.ma[context.datasetIndex === 0 ? 'up' : context.datasetIndex === 1 ? 'down' : 'ns'][context.dataIndex];
                                                    return point.label ? [
                                                        `Gene: ${point.label}`,
                                                        `x: ${context.parsed.x.toFixed(2)}, y: ${context.parsed.y.toFixed(2)}`
                                                    ] : `x: ${context.parsed.x.toFixed(2)}, y: ${context.parsed.y.toFixed(2)}`;
                                                }
                                            }
                                        }
                                    },
                                    scales: {
                                        x: {
                                            title: {
                                                display: true,
                                                text: 'Mean Expression (log scale)'
                                            }
                                        },
                                        y: {
                                            title: {
                                                display: true,
                                                text: 'log2 Fold Change'
                                            }
                                        }
                                    }
                                }
                            });
                        }
                    }

                    // Volcano Plot
                    if (plotData_<%= figIdx %>.volcano && (plotData_<%= figIdx %>.volcano.up.length > 0 || plotData_<%= figIdx %>.volcano.down.length > 0 || plotData_<%= figIdx %>.volcano.ns.length > 0)) {
                        const volcanoCtx_<%= figIdx %> = document.getElementById('volcano-chart-<%= figIdx %>');
                        if (volcanoCtx_<%= figIdx %>) {
                            const volcanoChart_<%= figIdx %> = new Chart(volcanoCtx_<%= figIdx %>.getContext('2d'), {
                                type: 'scatter',
                                data: {
                                    datasets: [
                                        {
                                            label: 'Up-regulated',
                                            data: plotData_<%= figIdx %>.volcano.up.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(239, 68, 68, 0.6)',
                                            pointRadius: 3,
                                            pointHoverRadius: 6
                                        },
                                        {
                                            label: 'Down-regulated',
                                            data: plotData_<%= figIdx %>.volcano.down.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(59, 130, 246, 0.6)',
                                            pointRadius: 3,
                                            pointHoverRadius: 6
                                        },
                                        {
                                            label: 'Not significant',
                                            data: plotData_<%= figIdx %>.volcano.ns.map(function(p) { return { x: p.x, y: p.y }; }),
                                            backgroundColor: 'rgba(156, 163, 175, 0.4)',
                                            pointRadius: 2,
                                            pointHoverRadius: 4
                                        }
                                    ]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: {
                                        legend: {
                                            position: 'top',
                                        },
                                        title: {
                                            display: true,
                                            text: 'Volcano Plot - <%= fig.comparison %>'
                                        },
                                        tooltip: {
                                            callbacks: {
                                                label: function(context) {
                                                    const point = plotData_<%= figIdx %>.volcano[context.datasetIndex === 0 ? 'up' : context.datasetIndex === 1 ? 'down' : 'ns'][context.dataIndex];
                                                    return point.label ? [
                                                        `Gene: ${point.label}`,
                                                        `log2FC: ${context.parsed.x.toFixed(2)}, -log10(pval): ${context.parsed.y.toFixed(2)}`
                                                    ] : `log2FC: ${context.parsed.x.toFixed(2)}, -log10(pval): ${context.parsed.y.toFixed(2)}`;
                                                }
                                            }
                                        }
                                    },
                                    scales: {
                                        x: {
                                            title: {
                                                display: true,
                                                text: 'log2 Fold Change'
                                            }
                                        },
                                        y: {
                                            title: {
                                                display: true,
                                                text: '-log10(P-value)'
                                            }
                                        }
                                    }
                                }
                            });
                        }
                    }
                <% } %>
            <% }); %>
        <% } %>
    </script>
</body>
</html>
