                            <th>Total Bases</th>
                            <th>Data (GB)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% sequencing_stats.forEach(function(s) { %>
                        <tr>
                            <td><%=  s.sample  %></td>
                            <td class="mono"><%=  s.total_reads_r1  %></td>
                            <td class="mono"><%=  s.total_reads_r2  %></td>
                            <td class="mono"><%=  s.total_reads  %></td>
