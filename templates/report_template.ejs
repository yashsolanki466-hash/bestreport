<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title> Unigenome <%=  project_id  %></title>

    <!-- Dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary-color: #F47920;
            --secondary-color: #1A365D;
            --accent-color: #3182CE;
            --text-main: #2D3748;
            --text-muted: #718096;
            --bg-body: #F7FAFC;
            --bg-sidebar: rgba(255, 255, 255, 0.85);
            --bg-paper: #FFFFFF;
            --border-color: #E2E8F0;
            --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --glass-blur: blur(12px);
        }

        body {
            font-family: "Times New Roman", Times, serif;
            font-size: 13pt;
            line-height: 1.75;
            color: var(--text-main);
            background-color: var(--bg-body);
            margin: 0;
            padding-left: 280px;
            transition: background-color 0.3s ease, color 0.3s ease;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        h1,
        h2,
        h3,
        h4,
        .ui-font {
            font-family: "Times New Roman", Times, serif;
        }

        p {
            margin-bottom: 1.2rem;
            text-align: justify;
        }

        .section {
            scroll-margin-top: 40px;
        }

        #progress-container {
            position: fixed;
            top: 0;
            left: 280px;
            right: 0;
            height: 4px;
            background: rgba(0, 0, 0, 0.05);
            z-index: 1001;
        }

        #progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
            transition: width 0.1s ease-out;
        }

        /* Fixed TOC Sidebar Style (Screen Only) */
        #TOC {
            position: fixed;
            top: 0;
            left: 0;
            width: 280px;
            height: 100vh;
            overflow-y: auto;
            background: var(--bg-sidebar);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-right: 1px solid var(--border-color);
            padding: 40px 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        .toc-header {
            padding: 0 32px 24px 32px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        #TOC ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        #TOC li a {
            display: block;
            padding: 12px 32px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-left: 4px solid transparent;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #TOC li a:hover {
            color: var(--secondary-color);
            background: rgba(0, 0, 0, 0.02);
        }

        #TOC li a.active {
            color: var(--secondary-color);
            background: rgba(49, 130, 206, 0.08);
            border-left: 4px solid var(--secondary-color);
            font-weight: 600;
        }

        /* Sidebar submenu styles */
        #TOC ul.toc-submenu {
            list-style: none;
            padding-left: 0;
            margin: 0;
            display: none; /* Collapsed by default */
        }
        #TOC ul.toc-submenu.expanded {
            display: block;
        }
        #TOC li.has-children > .toc-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #TOC li.has-children > .toc-row a {
            flex-grow: 1;
            padding-right: 8px;
        }
        .toc-toggle-btn {
            padding: 12px 20px 12px 8px;
            color: var(--text-muted);
            cursor: pointer;
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
        }
        .toc-toggle-btn.rotated {
            transform: rotate(180deg);
        }

        /* Sidebar subsection indentation */
        #TOC li a.toc-level-2 {
            padding-left: 45px;
            font-size: 13px;
        }
        #TOC li a.toc-level-3 {
            padding-left: 60px;
            font-size: 12px;
        }

        /* Content Area */
        .main-container {
            margin: 40px auto;
            padding: 80px 100px;
            max-width: 1000px;
            background-color: var(--bg-paper);
            box-shadow: var(--card-shadow);
            border-radius: 8px;
            box-sizing: border-box;
            border: 1px solid var(--border-color);
        }

        /* Cover Page */
        .cover-page {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            text-align: center;
            padding: 50px;
            box-sizing: border-box;
            page-break-after: always;
        }

        .cover-logo {
            max-width: 300px;
            margin-bottom: 40px;
        }

        .cover-title {
            font-size: 34px;
            font-weight: 800;
            color: #000;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .cover-subtitle {
            font-size: 22px;
            font-weight: 600;
            color: #000;
            margin-bottom: 40px;
        }

        .cover-details {
            font-size: 16px;
            color: var(--primary-color);
            font-weight: bold;
            margin-bottom: 60px;
        }

        .submitted-by {
            margin-top: 25px;
            color: #333;
            font-size: 12px;
            line-height: 1.4;
        }

        .toc-page {
            page-break-after: always;
            display: none;
        }

        .toc-title {
            font-size: 22px;
            font-weight: 800;
            color: var(--secondary-color);
            margin-bottom: 14px;
        }

        .toc-list {
            list-style: none;
            padding: 0;
            margin: 0 auto;
            max-width: 650px;
            font-family: "Times New Roman", Times, serif;
            line-height: 2.0;
        }

        .toc-list li {
            margin-bottom: 4px;
        }

        .toc-list li.level-1 {
            font-weight: bold;
            font-size: 15px;
            margin-top: 10px;
        }

        .toc-list li.level-2 {
            padding-left: 24px;
            font-size: 14px;
            font-weight: normal;
        }

        .toc-list li.level-3 {
            padding-left: 48px;
            font-size: 13.5px;
            font-weight: normal;
        }

        .toc-list a {
            display: flex;
            align-items: flex-end;
            text-decoration: none;
            color: var(--text-main);
        }

        .toc-list .title {
            white-space: normal;
        }

        .toc-list .dots {
            flex-grow: 1;
            border-bottom: 2px dotted #555;
            margin: 0 6px;
            position: relative;
            top: -4px;
        }

        .toc-list .page {
            white-space: nowrap;
            text-align: right;
            min-width: 24px;
            font-weight: bold;
        }

        .toc-list li.level-2 .page,
        .toc-list li.level-3 .page {
            font-weight: normal;
        }

        .submitted-to {
            margin-top: auto;
            color: var(--secondary-color);
            font-weight: bold;
            font-size: 18px;
        }

        /* Typography */
        h1.title {
            font-size: 28px;
            margin-top: 0;
            margin-bottom: 10px;
            font-weight: 700;
            color: var(--secondary-color);
        }

        .subtitle {
            font-size: 16px;
            color: #666;
            margin-bottom: 30px;
            font-weight: 400;
        }

        h2 {
            font-size: 22px;
            color: var(--secondary-color);
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 8px;
            margin-top: 40px;
            margin-bottom: 20px;
            font-weight: 700;
            page-break-after: avoid;
        }

        h3 {
            font-size: 16px;
            font-weight: bold;
            margin-top: 25px;
            margin-bottom: 15px;
            color: var(--secondary-color);
            page-break-after: avoid;
        }

        h4 {
            font-size: 14px;
            font-weight: bold;
            margin-top: 20px;
            margin-bottom: 10px;
            color: #555;
        }

        p {
            margin-bottom: 15px;
            text-align: justify;
        }

        /* Tables */
        .table-wrapper {
            overflow-x: auto;
            margin: 20px 0 30px 0;
            page-break-inside: avoid;
        }

        .table-title {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 8px;
            color: var(--secondary-color);
        }

        table {
            width: 100%;
            max-width: 100%;
            border-spacing: 0;
            border-collapse: collapse;
            border: 1px solid #ddd;
            font-size: 11px;
            /* Smaller for print readiness */
        }

        table th {
            padding: 8px 10px;
            background-color: var(--secondary-color);
            color: #fff;
            border: 1px solid var(--secondary-color);
            text-align: left;
            font-weight: 700;
            text-transform: uppercase;
        }

        table td {
            padding: 6px 10px;
            border: 1px solid #ddd;
            vertical-align: middle;
        }

        table tr:nth-of-type(even) {
            background-color: #f2f2f2;
        }

        /* Figures */
        .figure {
            margin: 30px 0;
            text-align: center;
            background: #fff;
            padding: 10px;
            /* border: 1px solid #eee; */
            page-break-inside: avoid;
        }

        .figure img {
            max-width: 100%;
            height: auto;
        }

        .pdf-link {
            display: inline-block;
            padding: 8px 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            color: var(--secondary-color);
            text-decoration: none;
            background: #fafafa;
            font-size: 12px;
        }

        .pdf-link:hover {
            background: #f0f0f0;
        }

        .caption {
            font-size: 11px;
            color: var(--secondary-color);
            margin-top: 10px;
            font-style: italic;
            font-weight: 600;
        }

        /* Info Box */
        .info-box {
            padding: 20px;
            margin-bottom: 25px;
            border-left: 5px solid var(--primary-color);
            background-color: #f9f9f9;
            color: #333;
        }

        .mono {
            font-family: "Times New Roman", Times, serif;
            font-size: 11px;
        }

        .confidential {
            color: #999;
            font-size: 10px;
            margin-top: 5px;
            text-align: right;
        }

        /* Footer for Print - Browser Compatible */
        .print-footer {
            display: none;
        }

        /* Print-only repeating header */
        .print-header {
            display: none;
        }

        @media print {
            .print-header {
                display: block !important;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                height: 45mm;
                padding: 5mm 25mm 0 25mm;
                background: white !important;
                z-index: 9999;
                box-sizing: border-box;
                border-top: 6mm solid var(--primary-color) !important;
            }

            .header-top {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 2mm;
            }

            .header-address {
                font-size: 6.8pt;
                color: #444;
                line-height: 1.4;
                text-align: left;
                flex-grow: 1;
            }

            .print-header img {
                height: 12mm;
                width: auto;
                margin-left: 15px;
                display: block;
            }

            .header-info-line {
                border-bottom: 0.5pt solid #ddd;
                padding-bottom: 1mm;
                display: flex;
                justify-content: flex-end;
                font-size: 8pt;
                font-weight: 500;
                color: #333;
                margin-top: 1.5mm;
            }
        }

        @media screen and (max-width: 992px) {
            #TOC {
                display: none;
            }

            body {
                padding-left: 0;
            }

            .main-container {
                margin: 0 auto;
                padding: 20px;
            }
        }

        /* Search Input */
        .table-search-container {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(0, 0, 0, 0.02);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0 16px;
        }

        .table-search {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 13px;
            outline: none;
            color: var(--text-main);
            background: #fff;
        }

        th.sortable {
            cursor: pointer;
            position: relative;
            padding-right: 24px;
        }

        /* Print Formatting */
        @media print {
            @page {
                size: A4;
                margin: 50mm 25mm 25mm 25mm;
            }

            @page :first {
                margin: 15mm 25mm 25mm 25mm;
            }

            body {
                background-color: #fff !important;
                font-size: 10.5pt;
                line-height: 1.55;
                margin: 0;
                padding: 0 !important;
                width: 100% !important;
            }

            p {
                orphans: 3;
                widows: 3;
            }

            #TOC {
                display: none;
            }

            .main-container {
                margin: 0 auto;
                padding: 0;
                width: 100%;
                max-width: none;
                background: transparent;
                box-shadow: none;
                border-radius: 0;
            }

            h2 {
                margin-top: 0;
                padding-top: 14px;
            }

            .toc-page {
                break-before: page;
                page-break-before: always;
            }

            #section-1,
            #section-2,
            #section-3,
            #section-4,
            #section-5,
            #section-6,
            #section-7,
            #section-8,
            #section-9,
            #section-10,
            #section-11,
            #section-12 {
                break-before: page;
                page-break-before: always;
            }

            .toc-page {
                display: block;
            }

            .table-wrapper,
            table,
            .figure {
                break-inside: avoid;
            }

            thead {
                display: table-header-group;
            }

            tfoot {
                display: table-footer-group;
            }

            /* Avoid breaking after h2/h3 */
            h2,
            h3 {
                page-break-after: avoid;
            }

            /* Cover page print fixes */
            .cover-page {
                height: 280mm;
                min-height: 100vh;
                margin: 0;
                padding: 40px 0;
                page-break-after: always;
                justify-content: space-between;
                box-sizing: border-box;
            }

            /* Print footer with page number support */
            .print-footer {
                position: fixed;
                bottom: -20mm;
                left: 0;
                right: 0;
                text-align: center;
                font-size: 9pt;
                color: #666;
            }

            /* Hide interactive elements if any */
            .no-print {
                display: none;
            }

            /* Zebra striping for tables */
            tbody tr:nth-child(even) {
                background-color: #f5f5f5;
            }

            a {
                text-decoration: none;
                color: inherit;
            }

            /* Ensure background colors print */
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

        }

        /* Utility classes for comparison toggles */
        .hidden {
            display: none !important;
        }

        .comp-btn.active {
            background: var(--primary-color) !important;
            color: #fff !important;
        }

        /* ============================================
           PRINT STYLES - For PDF Generation
           ============================================ */
        @media print {
            @page {
                size: A4;
                margin: 20mm 15mm 25mm 15mm;
                
                @bottom-center {
                    content: "Page " counter(page) " of " counter(pages);
                    font-size: 9pt;
                    color: #666;
                }
            }
            
            @page :first {
                margin: 0;
                @bottom-center { content: none; }
            }

            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }

            body {
                font-family: Georgia, "Times New Roman", serif;
                font-size: 11pt;
                line-height: 1.6;
                color: #2D3748;
                background: white !important;
                padding: 0 !important;
                margin: 0 !important;
            }

            /* Hide sidebar and navigation for print */
            #TOC,
            #progress-container,
            .table-search-container,
            .download-btn {
                display: none !important;
            }

            /* Main container adjustments */
            .main-container {
                max-width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                background: white !important;
                box-shadow: none !important;
                border: none !important;
            }

            /* Cover page */
            .cover-page {
                height: 100vh;
                page-break-after: always;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 40px;
                background: white !important;
            }

            .cover-logo {
                max-width: 250px;
                margin-bottom: 30px;
            }

            .cover-title {
                font-size: 28pt;
                font-weight: bold;
                color: #000;
                margin-bottom: 15px;
                text-transform: uppercase;
            }

            .cover-subtitle {
                font-size: 18pt;
                font-weight: 600;
                color: #333;
                margin-bottom: 30px;
            }

            /* Section styling */
            .section {
                page-break-inside: avoid;
                margin-bottom: 20pt;
            }

            h1 {
                font-size: 18pt;
                color: #1A365D;
                border-bottom: 2pt solid #F47920;
                padding-bottom: 8pt;
                margin: 20pt 0 12pt 0;
                page-break-after: avoid;
            }

            h2 {
                font-size: 14pt;
                color: #1A365D;
                margin: 16pt 0 10pt 0;
                page-break-after: avoid;
            }

            h3 {
                font-size: 12pt;
                color: #2D3748;
                margin: 12pt 0 8pt 0;
                page-break-after: avoid;
            }

            h4 {
                font-size: 11pt;
                color: #2D3748;
                margin: 10pt 0 6pt 0;
                page-break-after: avoid;
            }

            p {
                text-align: justify;
                margin-bottom: 10pt;
                orphans: 3;
                widows: 3;
            }

            /* Table styling for print */
            .table-wrapper {
                margin: 15pt 0;
                page-break-inside: avoid;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                font-size: 9pt;
                page-break-inside: avoid;
            }

            thead {
                display: table-header-group;
            }

            th {
                background-color: #1A365D !important;
                color: white !important;
                font-weight: bold;
                padding: 8pt 6pt;
                text-align: left;
                border: 1pt solid #1A365D;
            }

            td {
                padding: 6pt;
                border: 0.5pt solid #E2E8F0;
                vertical-align: top;
            }

            tr:nth-child(even) {
                background-color: #F7FAFC !important;
            }

            /* Image styling */
            img {
                max-width: 100%;
                height: auto;
                page-break-inside: avoid;
            }

            .chart-container,
            .figure-container {
                page-break-inside: avoid;
                margin: 15pt 0;
                text-align: center;
            }

            figure {
                page-break-inside: avoid;
                margin: 15pt 0;
            }

            figcaption {
                font-size: 9pt;
                color: #666;
                text-align: center;
                margin-top: 5pt;
            }

            /* List styling */
            ul, ol {
                margin: 10pt 0;
                padding-left: 20pt;
            }

            li {
                margin-bottom: 4pt;
            }

            /* Info boxes and cards */
            .info-box,
            .highlight-box {
                border: 1pt solid #E2E8F0;
                padding: 10pt;
                margin: 10pt 0;
                background-color: #F7FAFC !important;
                page-break-inside: avoid;
            }

            /* Links */
            a {
                color: #3182CE;
                text-decoration: none;
            }

            a[href]:after {
                content: " (" attr(href) ")";
                font-size: 8pt;
                color: #666;
            }

            /* Page breaks */
            .page-break {
                page-break-before: always;
            }

            .no-break {
                page-break-inside: avoid;
            }

            /* Footer content */
            .footer-content {
                font-size: 8pt;
                color: #666;
                text-align: center;
                margin-top: 20pt;
                border-top: 0.5pt solid #E2E8F0;
                padding-top: 10pt;
            }

            /* Sample info cards */
            .sample-card {
                border: 1pt solid #E2E8F0;
                padding: 10pt;
                margin: 8pt 0;
                page-break-inside: avoid;
            }

            /* Quality metrics */
            .quality-metric {
                display: inline-block;
                margin: 3pt 6pt;
                padding: 4pt 8pt;
                background-color: #F7FAFC !important;
                border: 0.5pt solid #E2E8F0;
                font-size: 9pt;
            }

            /* Two column layout for print */
            .two-column {
                column-count: 2;
                column-gap: 20pt;
            }

            /* Prevent orphans and widows */
            p, li {
                orphans: 3;
                widows: 3;
            }
        }
    </style>
</head>

<body>

    <div id="progress-container">
        <div id="progress-bar"></div>
    </div>

    <% var static_snippets = static_content ? static_content['snippets'] || {} : {}; %>

    <div class="print-header">
        <div class="header-top">
            <div class="header-address">
                <span style="font-weight: 700; color: var(--secondary-color); margin-bottom: 1px; display: block;">Lab
                    Facility:</span>
                2A, 3A, 3B PASL -House, Beside Sahjanand college, Opposite Kamdenu Complex,<br>
                Panjarapole, Ambawadi, Ahmedabad-380015, Gujarat<br>
                Ph:+91-79-49006800 | WhatsApp: +91-6356005900 | Email: info@unigenome.in | Website: www.unigenome.in
            </div>
            <img src="<%=  logo_path  %>" alt="Logo" />
        </div>
        <div class="header-info-line">
            NGS-<%=  project_id  %> | Date: <%=  report_date  %>
        </div>
    </div>

    <div id="TOC">
        <div class="toc-header">
            <div
                style="font-weight: 800; color: var(--primary-color); font-size: 18px; letter-spacing: 0.5px; font-family: 'Times New Roman', Times, serif;">
                UNIGENOME</div>
            <div style="font-size: 12px; color: var(--text-muted); font-family: 'Times New Roman', Times, serif;">Final Analysis
                Report</div>
        </div>
        <ul style="margin-top: 10px;">
            <li><a href="#section-1" class="active"><i data-lucide="info"
