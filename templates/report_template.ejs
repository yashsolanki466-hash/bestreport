        <!-- Section 10 -->
        <div id="section-10" class="section">
            <h2>10 Differential Expression</h2>
            <p><%=  static_snippets.dge?.intro || ''  %></p>

            <h3>Comparison information</h3>
            <div class="table-wrapper">
                <div class="table-title">Table 10.1: Comparison information</div>
                <% var dge_cmp = dge_comparison_table || static_snippets.dge?.comparison_info_table || {}; %>
