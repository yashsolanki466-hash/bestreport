            <p><%=  static_snippets.dge?.deseq2_intro || ''  %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.3: Column description of DESeq2 output</div>
                <% var dge_cols = static_snippets.dge?.deseq2_columns_table || {}; %>
