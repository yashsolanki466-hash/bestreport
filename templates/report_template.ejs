            <p><%=  static_snippets.dge?.criteria_intro || ''  %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.4: Criteria used to identify upregulated and downregulated genes and
                    assigning the significance</div>
                <% var dge_crit = static_snippets.dge?.criteria_table || {}; %>
                <% var dge_crit_rows = dge_crit ? dge_crit['rows'] || [] : []; %>
                <% if (dge_crit_rows && dge_crit_rows.length > 0 ) { %>
                <table>
                    <thead>
                        <tr>
                            <% (dge_crit['headers'] || []).forEach(function(h) { %>
                            <th><%=  h  %></th>
                            <% }); %>
                        </tr>
                    </thead>
                    <tbody>
                        <% dge_crit_rows.forEach(function(r) { %>
                        <tr>
                            <td><%=  r[0]  %></td>
                            <td><%=  r[1]  %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <% } %>
            </div>

            <p><%=  static_snippets.dge?.stats_note || ''  %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.5: Differential gene expression statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Comparison</th>
                            <th>Total DEGs</th>
                            <th>Sig. Down</th>
                            <th>Sig. Up</th>
                            <th>Total Significant</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% diff_expr_stats.forEach(function(d) { %>
                        <tr>
                            <td><%=  d.comparison  %></td>
                            <td><%=  d.total_degs  %></td>
                            <td><%=  d.sig_down  %></td>
                            <td><%=  d.sig_up  %></td>
                            <td class="font-bold"><%=  d.total_sig  %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <p><%=  static_snippets.dge?.annotation_note || ''  %></p>

            <% if (dge_figures && dge_figures.length > 0 ) { %>
            <h3>10.1 MA Plot for differentially expressed genes</h3>
            <p><%=  static_snippets.dge?.ma_plot_text || ''  %></p>

            <h3>10.2 Volcano plot for differentially expressed genes</h3>
            <p><%=  static_snippets.dge?.volcano_plot_text || ''  %></p>

            <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 16px;">Select a comparison to view
                interactive MA and Volcano plots.</p>

            <!-- Comparison Selector -->
            <div class="comp-toggles" style="margin-bottom: 20px; display: flex; flex-wrap: wrap; gap: 8px;">
                <% dge_figures.forEach(function(fig, index) { %>
                <button class="chart-btn comp-btn <%= index === 0 ? 'active' : '' %>"
                    onclick="showComparison('<%=  fig.comparison  %>')" data-comparison="<%=  fig.comparison  %>"
                    style="padding: 8px 16px; border: 1px solid var(--border-light); background: #fff; color: var(--text-main); border-radius: 4px; cursor: pointer; font-size: 12px;">
                    <%=  fig.comparison  %>
                </button>
                <% }); %>
            </div>

            <!-- Plots Container -->
            <% dge_figures.forEach(function(fig, index) { %>
            <div id="plot-<%=  fig.comparison  %>" class="comparison-plots <%= index === 0 ? '' : 'hidden' %>"
                style="margin-bottom: 30px;">

                <% if (fig.plot_data_json ) { %>
                <script type="application/json" id="plotdata-<%=  fig.comparison  %>"><%=  fig.plot_data_json  %></script>
                <% } %>

                <h4 style="color: var(--primary); margin-bottom: 16px; font-size: 14px;">
                    Comparison: <%=  fig.comparison  %>
                </h4>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <!-- MA Plot -->
                    <div class="card"
                        style="border: 1px solid var(--border-light); border-radius: 4px; overflow: hidden;">
                        <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid var(--border-light);
                                    display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 600; font-size: 12px;">MA Plot</span>
                            <div style="display: flex; gap: 6px;">
                                <button class="chart-btn" onclick="expandPlot('ma-<%=  fig.comparison  %>')" title="Expand"
                                    style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd;">⛶</button>
                                <a href="<%=  fig.ma_volcano_pdf_src  %>" target="_blank" class="chart-btn"
                                    title="Download PDF"
                                    style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd; text-decoration: none;">⬇</a>
                            </div>
                        </div>
                        <div style="height: 350px; padding: 15px;">
                            <% if (fig.ma_plot_data ) { %>
                            <canvas id="ma-<%=  fig.comparison  %>" class="ma-plot-canvas"></canvas>
                            <% } else { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; 
                                        background: #f8f9fa; border-radius: 4px;">
                                <a href="<%=  fig.ma_volcano_pdf_src  %>" target="_blank" class="pdf-link" style="padding: 12px 24px; background: var(--primary); color: white; 
                                          text-decoration: none; border-radius: 4px; font-size: 13px;">
                                    View MA Plot (PDF)
                                </a>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Volcano Plot -->
                    <div class="card"
                        style="border: 1px solid var(--border-light); border-radius: 4px; overflow: hidden;">
                        <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid var(--border-light);
                                    display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 600; font-size: 12px;">Volcano Plot</span>
                            <div style="display: flex; gap: 6px;">
                                <button class="chart-btn" onclick="expandPlot('volcano-<%=  fig.comparison  %>')"
                                    title="Expand"
                                    style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd;">⛶</button>
                                <a href="<%=  fig.ma_volcano_pdf_src  %>" target="_blank" class="chart-btn"
                                    title="Download PDF"
                                    style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd; text-decoration: none;">⬇</a>
                            </div>
                        </div>
                        <div style="height: 350px; padding: 15px;">
                            <% if (fig.volcano_plot_data ) { %>
                            <canvas id="volcano-<%=  fig.comparison  %>" class="volcano-plot-canvas"></canvas>
                            <% } else { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; 
                                        background: #f8f9fa; border-radius: 4px;">
                                <a href="<%=  fig.ma_volcano_pdf_src  %>" target="_blank" class="pdf-link" style="padding: 12px 24px; background: var(--primary); color: white; 
                                          text-decoration: none; border-radius: 4px; font-size: 13px;">
                                    View Volcano Plot (PDF)
                                </a>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Heatmap -->
                <% if (fig.heatmap_png_src ) { %>
                <div class="figure" style="margin-top: 20px;">
                    <div style="border: 1px solid var(--border-light); border-radius: 4px; overflow: hidden;">
                        <div
                            style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid var(--border-light];">
                            <span style="font-weight: 600; font-size: 12px;">Expression Heatmap - <%=  fig.comparison
                                 %></span>
                        </div>
                        <div style="padding: 15px;">
                            <img src="<%=  fig.heatmap_png_src  %>" alt="<%=  fig.comparison  %> heatmap"
                                style="max-width: 100%; height: auto;" />
                        </div>
                    </div>
                    <p class="caption">Heatmap of significantly differentially expressed genes for <%=  fig.comparison  %>
                    </p>
                </div>
                <% } %>
            </div>
            <% }); %>

            <script>
                const __dgeCharts = { ma: {}, volcano: {} };

                function __getPlotData(comp) {
                    const el = document.getElementById('plotdata-' + comp);
                    if (!el) return null;
                    try {
                        return JSON.parse(el.textContent || '');
                    } catch (e) {
                        return null;
                    }
                }

                function __makeScatterChart(canvasId, titleText, datasets, xLabel, yLabel) {
                    const canvas = document.getElementById(canvasId);
                    if (!canvas) return null;
                    const ctx = canvas.getContext('2d');
                    if (!ctx) return null;

                    return new Chart(ctx, {
                        type: 'scatter',
                        data: { datasets },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: true, position: 'top' },
                                title: { display: false, text: titleText },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            const x = context.parsed.x !== undefined ? context.parsed.x.toFixed(2) : 'N/A';
                                            const y = context.parsed.y !== undefined ? context.parsed.y.toFixed(2) : 'N/A';
                                            const label = context.raw && context.raw.label ? context.raw.label : '';
                                            const datasetLabel = context.dataset.label;
                                            if (label && (datasetLabel === 'Up' || datasetLabel === 'Down')) {
                                                return `${label}: (${x}, ${y})`;
                                            }
                                            return `(${x}, ${y})`;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: { title: { display: true, text: xLabel } },
                                y: { title: { display: true, text: yLabel } }
                            },
                            elements: {
                                point: { radius: 2, hoverRadius: 4 }
                            }
                        }
                    });
                }

                function __renderComparisonPlots(comp) {
                    const data = __getPlotData(comp);
                    if (!data) return;

                    // MA plot
                    const maCanvasId = 'ma-' + comp;
                    if (data.ma && !__dgeCharts.ma[comp] && document.getElementById(maCanvasId)) {
                        const ds = [];
                        if (data.ma.ns && data.ma.ns.length) ds.push({ label: 'Not Sig', data: data.ma.ns, backgroundColor: 'rgba(156,163,175,0.45)' });
                        if (data.ma.down && data.ma.down.length) ds.push({ label: 'Down', data: data.ma.down, backgroundColor: 'rgba(59,130,246,0.65)' });
                        if (data.ma.up && data.ma.up.length) ds.push({ label: 'Up', data: data.ma.up, backgroundColor: 'rgba(239,68,68,0.65)' });
                        __dgeCharts.ma[comp] = __makeScatterChart(maCanvasId, 'MA Plot', ds, 'logCPM', 'log2FC');
                    }

                    // Volcano plot
                    const volCanvasId = 'volcano-' + comp;
                    if (data.volcano && !__dgeCharts.volcano[comp] && document.getElementById(volCanvasId)) {
                        const ds = [];
                        if (data.volcano.ns && data.volcano.ns.length) ds.push({ label: 'Not Sig', data: data.volcano.ns, backgroundColor: 'rgba(156,163,175,0.45)' });
                        if (data.volcano.down && data.volcano.down.length) ds.push({ label: 'Down', data: data.volcano.down, backgroundColor: 'rgba(59,130,246,0.65)' });
                        if (data.volcano.up && data.volcano.up.length) ds.push({ label: 'Up', data: data.volcano.up, backgroundColor: 'rgba(239,68,68,0.65)' });
                        __dgeCharts.volcano[comp] = __makeScatterChart(volCanvasId, 'Volcano Plot', ds, 'log2FC', '-log10(p)');
                    }
                }

                function showComparison(comp) {
                    // Hide all plot containers
                    document.querySelectorAll('.comparison-plots').forEach(el => {
                        el.classList.add('hidden');
                    });

                    // Show selected
                    const target = document.getElementById('plot-' + comp);
                    if (target) target.classList.remove('hidden');

                    // Update button active state
                    document.querySelectorAll('.comp-toggles .comp-btn').forEach(btn => {
                        btn.classList.toggle('active', btn.dataset.comparison === comp);
                    });

                    // Render charts lazily
                    __renderComparisonPlots(comp);
                }

                function expandPlot(canvasId) {
                    const canvas = document.getElementById(canvasId);
                    if (canvas) {
                        // Simple expand - open in new window
                        const win = window.open('', '_blank');
                        win.document.write('<html><head><title>Plot</title></head><body style="margin:0; display:flex; align-items:center; justify-content:center; min-height:100vh;">');
                        win.document.write('<img src="' + canvas.toDataURL() + '" style="max-width:100%; max-height:100vh;"/>');
                        win.document.write('</body></html>');
                    }
                }

                // Render first comparison (if any)
                (function initFirstDgeComparison() {
                    const firstBtn = document.querySelector('.comp-toggles .comp-btn');
                    if (firstBtn && firstBtn.dataset && firstBtn.dataset.comparison) {
                        __renderComparisonPlots(firstBtn.dataset.comparison);
                    }
                })();
            </script>
            <% } %>
        </div>

        <!-- Section 11 -->
        <div id="section-11" class="section">
            <h4>5.8.4. Gene Ontology (GO) analysis for significant DEG</h4>
            <p>
                The Gene Ontology project provides controlled vocabularies of defined terms representing gene product
                properties. These cover three domains: Cellular Component, the parts of a cell or its extracellular
                environment; Molecular Function, the elemental activities of a gene product at the molecular level, such
                as binding or catalysis; and Biological Process, operations or sets of molecular events with a defined
                beginning and end, pertinent to the functioning of integrated living units: cells, tissues, organs, and
                organisms. GO was assigned to significant differentially expressed transcripts using Blast2go cli.
                Single gene can be assigned with multiple GO categories and hence multiple GO terms. The GO domain
                distribution is shown in table below:
            </p>

            <div class="table-wrapper">
                <div class="table-title">Table 5.8.6: GO Distribution of Significantly Differential expression transcripts</div>
                <table>
                    <thead>
                        <tr>
                            <th>Sample Name</th>
                            <th>Significant DGE</th>
                            <th># Seq with GO</th>
                            <th>Biological Process</th>
                            <th>Cellular Component</th>
                            <th>Molecular Function</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% go_distribution.forEach(function(g) { %>
                        <tr>
                            <td>
                                <%= g.combination %>
                            </td>
                            <td>
                                <%= g.sig_dge %>
                            </td>
                            <td>
                                <%= g.sq_go %>
                            </td>
                            <td>
                                <%= g.bp %>
                            </td>
                            <td>
                                <%= g.cc %>
                            </td>
                            <td>
                                <%= g.mf %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <h4>5.8.5. Pathway analysis for significant DGE</h4>
            <p>Mapping of significantly differentially expressed transcripts to biological pathways was performed using
                <strong>KEGG-KAAS</strong>. Results represent metabolic pathways of major biomolecules.
            </p>

            <div class="table-wrapper">
                <div class="table-title">Table 5.8.7: KEGG Pathway Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Level 1 Category</th>
                            <th>Level 2 Sub-Category</th>
                            <th>Gene Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pathway_stats.forEach(function(p) { %>
                        <tr>
                            <td><%=  p.level1  %></td>
                            <td><%=  p.level2  %></td>
                            <td><%=  p.count  %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <% if (func_assets && func_assets.kegg_pathway_image_src ) { %>
            <div class="figure">
                <img src="<%=  func_assets.kegg_pathway_image_src  %>" alt="KEGG pathway" />
                <p class="caption">Figure 5.8.5: Representative KEGG pathway image</p>
            </div>
            <% } %>

            <% if (pathway_ex_figure_src && (!func_assets || !func_assets.kegg_pathway_image_src) ) { %>
            <div class="figure">
                <img src="<%=  pathway_ex_figure_src  %>" alt="KEGG pathway example" />
                <p class="caption">Figure 5.8.5: Representative pathway example</p>
            </div>
            <% } %>

            <% if (func_assets && func_assets.kegg_results_preview && func_assets.kegg_results_preview.length > 0) { %>
            <h3>KEGG Pathway Statistics (preview)</h3>
            <% if (func_assets.kegg_results_xlsx) { %>
            <div class="figure">
                <a class="pdf-link" href="<%= func_assets.kegg_results_xlsx %>" target="_blank" rel="noopener noreferrer">Open KEGG pathway results (XLSX)</a>
            </div>
            <% } %>
            <div class="table-wrapper">
                <div class="table-title">Table 5.8.7: KEGG Pathway Statistics (first 15 rows)</div>
                <table>
                    <thead>
                        <tr>
                            <% if (func_assets.kegg_results_preview[0]) { %>
                                <% func_assets.kegg_results_preview[0].forEach(function(col) { %>
                                <th><%= col %></th>
                                <% }); %>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% func_assets.kegg_results_preview.slice(1).forEach(function(row) { %>
                        <tr>
                            <% row.forEach(function(cell) { %>
                            <td><%= cell %></td>
                            <% }); %>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            
            <div class="table-note" style="color: var(--secondary-color); font-family: 'Times New Roman', Times, serif; font-weight: bold; margin-top: 15px; margin-bottom: 20px; font-size: 14.5px; line-height: 1.6;">
                <div style="margin-bottom: 5px;">Note:</div>
                <div style="padding-left: 20px; text-indent: -20px; margin-bottom: 4px; text-align: justify;">
                    (a) Non-specific organism pathway hits are obtained in pathway results due to lenient threshold (bit score: 60) applied in KAAS webserver.
                </div>
                <div style="padding-left: 20px; text-indent: -20px; text-align: justify;">
                    (b) Pathway stats for only one comparison has been shown above, however stats and images for all other combinations has been provided as a part of data deliverables “07_Significant_DGE_pathways”.
                </div>
            </div>
            <% } %>

            <h4>5.8.6. Over-representation (or enrichment) analysis</h4>
            <p><%= static_snippets.enrichment?.intro || 'Over-representation (enrichment) analysis is a statistical approach used to identify biological functions, pathways, or processes that are significantly over-represented.' %></p>

            <% if (func_assets && (func_assets.barplot_image_src || func_assets.dotplot_image_src || func_assets.enrichment_image_src)) { %>
            <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin: 20px 0;">
                <% if (func_assets.barplot_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.barplot_image_src %>" alt="Enrichment Barplot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Figure 5.8.6: Representative Enrichment Barplot</p>
                </div>
                <% } %>
                <% if (func_assets.dotplot_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.dotplot_image_src %>" alt="Enrichment Dotplot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Figure 5.8.7: Representative Enrichment Dotplot</p>
                </div>
                <% } %>
                <% if (!func_assets.barplot_image_src && !func_assets.dotplot_image_src && func_assets.enrichment_image_src) { %>
                <div class="figure" style="flex: 1; min-width: 300px; max-width: 500px; text-align: center;">
                    <img src="<%= func_assets.enrichment_image_src %>" alt="Enrichment Plot" style="width: 100%; height: auto; border: 1px solid #ddd; border-radius: 4px;" />
                    <p class="caption">Figure 5.8.6: Representative Enrichment Plot</p>
                </div>
                <% } %>
            </div>
            <% } %>
        </div>

        <!-- Section 12 Deliverables -->
        <div id="section-12" class="section">
            <h2>6. Deliverables</h2>
            <p>The following deliverables are provided with this report:</p>
            <ul>
                <li>Raw Data (FastQ)</li>
                <li>Clean Data</li>
                <li>Reference Genome & GFF</li>
                <li>BAM Alignment Files</li>
                <li>Gene Count Matrix</li>
                <li>Differential Expression Results</li>
                <li>GO & KEGG Enrichment Results</li>
            </ul>

            <h3>Project Directory Structure</h3>
            <div class="tree-container"
                style="background: #f8f9fa; border: 1px solid #ddd; border-radius: 4px; padding: 15px; font-family: 'Courier New', monospace; font-size: 10pt; line-height: 1.4; white-space: pre-wrap; overflow-x: auto;">
                <%=  deliverables_tree  %>
            </div>
        </div>

    </div>

    <script type="application/json" id="library-sizes-json"><%=  library_sizes | tojson  %></script>
    <script type="application/json" id="samples-json"><%=  samples | tojson  %></script>
    <script>
        // Data passed from Python
        const librarySizes = JSON.parse(document.getElementById('library-sizes-json').textContent);
        const sampleLabels = JSON.parse(document.getElementById('samples-json').textContent);
        // Initialize QC Chart
        if (document.getElementById('qcChart')) {
            const ctxQC = document.getElementById('qcChart').getContext('2d');
            new Chart(ctxQC, {
                type: 'bar',
                data: {
                    labels: sampleLabels,
                    datasets: [{
                        label: 'Mean Library Size (bp)',
                        data: librarySizes,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Size (bp)'
                            }
                        }
                    }
                }
            });
        }

        // DGE comparison bar chart intentionally removed (static narrative + tables only).
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide && typeof window.lucide.createIcons === 'function') {
                window.lucide.createIcons();
            }

            // Collapsible Accordion logic
            document.querySelectorAll('.toc-toggle-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const parentLi = this.closest('li.has-children');
                    const submenu = parentLi.querySelector('.toc-submenu');
                    if (submenu) {
                        submenu.classList.toggle('expanded');
                        this.classList.toggle('rotated');
                    }
                });
            });

            document.querySelectorAll('.toc-row a').forEach(link => {
                link.addEventListener('click', function(e) {
                    const parentLi = this.closest('li.has-children');
                    const btn = parentLi.querySelector('.toc-toggle-btn');
                    const submenu = parentLi.querySelector('.toc-submenu');
                    if (submenu) {
                        submenu.classList.toggle('expanded');
                        if (btn) btn.classList.toggle('rotated');
                    }
                });
            });

            // Highlight parent main link immediately upon clicking any sub-link
            document.querySelectorAll('#TOC a').forEach(link => {
                link.addEventListener('click', function(e) {
                    const isMainLink = link.closest('.toc-row') || (link.parentElement.parentElement === document.querySelector('#TOC > ul'));
                    if (isMainLink) {
                        document.querySelectorAll('#TOC > ul > li > a, #TOC > ul > li > .toc-row > a').forEach(a => a.classList.remove('active'));
                        link.classList.add('active');
                    } else {
                        const parentLi = link.closest('#TOC > ul > li.has-children');
                        if (parentLi) {
                            document.querySelectorAll('#TOC > ul > li > a, #TOC > ul > li > .toc-row > a').forEach(a => a.classList.remove('active'));
                            const mainA = parentLi.querySelector('.toc-row a');
                            if (mainA) mainA.classList.add('active');
                        }
                    }
                });
            });

            const progressBar = document.getElementById('progress-bar');
            if (progressBar) {
                window.addEventListener('scroll', () => {
                    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                    const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
                    progressBar.style.width = scrolled + "%";
                });
            }

            const sections = document.querySelectorAll('.section');
            const navLinks = document.querySelectorAll('#TOC > ul > li > a, #TOC > ul > li > .toc-row > a');
            if (sections.length && navLinks.length) {
                window.addEventListener('scroll', () => {
                    let current = "";
                    sections.forEach(section => {
                        const sectionTop = section.offsetTop;
                        if (pageYOffset >= (sectionTop - 120)) {
                            current = section.getAttribute('id');
                        }
                    });

                    if (current) {
                        let mappedCurrent = current;
                        const match = current.match(/^section-(\d+)$/);
                        if (match) {
                            const secNum = parseInt(match[1], 10);
                            if (secNum >= 5 && secNum <= 11) {
                                mappedCurrent = 'section-5';
                            }
                        }
                        navLinks.forEach(link => {
                            link.classList.remove('active');
                            if (link.getAttribute('href') === `#${mappedCurrent}`) {
                                link.classList.add('active');
                            }
                        });
                    }
                });
            }

            document.querySelectorAll('#TOC a').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    const targetId = this.getAttribute('href');
                    const targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        e.preventDefault();
                        targetElement.scrollIntoView({ behavior: 'smooth' });
                    }
                });
            });

            document.querySelectorAll('.table-wrapper').forEach(wrapper => {
                const table = wrapper.querySelector('table');
                if (!table) return;

                const rows = table.querySelectorAll('tbody tr');
                if (rows.length < 3) return;

                const searchContainer = document.createElement('div');
                searchContainer.className = 'table-search-container';
                searchContainer.innerHTML = `
                    <i data-lucide="search" style="width:16px; color:var(--text-muted); pointer-events:none;"></i>
                    <input type="text" class="table-search" placeholder="Search rows...">`;
                wrapper.insertBefore(searchContainer, table);

                if (window.lucide && typeof window.lucide.createIcons === 'function') {
                    window.lucide.createIcons({
                        attrs: { class: 'lucide-search-icon' },
                        parent: searchContainer
                    });
                }

                const input = searchContainer.querySelector('input');
                input.addEventListener('keyup', () => {
                    const filter = input.value.toLowerCase();
                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        row.style.display = text.includes(filter) ? '' : 'none';
                    });
                });

                const headers = table.querySelectorAll('th');
                headers.forEach((header, index) => {
                    header.classList.add('sortable');
                    header.addEventListener('click', () => {
                        const isAsc = header.dataset.sortOrder === 'asc';
                        const multiplier = isAsc ? -1 : 1;

                        const sortedRows = Array.from(rows).sort((a, b) => {
                            const aVal = (a.children[index]?.textContent || '').trim();
                            const bVal = (b.children[index]?.textContent || '').trim();

                            const aNum = parseFloat(aVal.replace(/,/g, ''));
                            const bNum = parseFloat(bVal.replace(/,/g, ''));

                            if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * multiplier;
                            return aVal.localeCompare(bVal, undefined, { numeric: true, sensitivity: 'base' }) * multiplier;
                        });

                        const tbody = table.querySelector('tbody');
                        sortedRows.forEach(row => tbody.appendChild(row));
                        header.dataset.sortOrder = isAsc ? 'desc' : 'asc';
                    });
                });
            });
        });
    </script>
</body>

</html>